---
interface Props {
  maxWidth?: string;
}

const { maxWidth = "1100px" } = Astro.props;
---

<div class="breakout relative left-1/2 -translate-x-1/2 w-screen overflow-x-auto px-4 flex flex-col items-center">
  <div class="w-full flex justify-center" style={`max-width: ${maxWidth};`}>
    <slot />
  </div>
</div>

<style>
  .breakout {
    margin-block-start: var(--space-media-before);
    padding-block-end: var(--space-media-after);
  }
  .breakout :global(.case-image),
  .breakout :global(.carousel) {
    margin-block-start: 0;
    padding-block-end: 0;
  }
  .breakout :global(svg) {
    display: block;
    height: auto;
    flex-shrink: 0;
  }
</style>
