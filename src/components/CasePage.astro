---
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Prose from './Prose.astro';
import TranslationNotice from './TranslationNotice.astro';
import CaseNav from './CaseNav.astro';
import CaseToc from './CaseToc.astro';
import type { LocalizedCaseProps } from '../lib/cases';

const { entry, contentLocale, isFallback } = Astro.props as LocalizedCaseProps;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <main class="py-12">
    {
      isFallback && (
        <div class="prose">
          <TranslationNotice contentLocale={contentLocale} />
        </div>
      )
    }
    <Prose as="article" lang={isFallback ? contentLocale : undefined}>
      <CaseNav variant="article" />
      <header class="case-hero !m-0 !pb-10">
        <h1 class="!m-0 !mb-4 !text-[30px] !leading-[1.2] !font-bold !tracking-[-0.02em]">
          {entry.data.title}
        </h1>
        {
          entry.data.meta && (
            <p class="case-hero__meta !m-0 !mb-4 !text-[14px] !leading-[1.5] !text-[var(--color-text-muted)]">
              {entry.data.meta}
            </p>
          )
        }
        {
          entry.data.subtitle && (
            <p class="case-hero__subtitle !m-0 !text-[18px] !leading-[1.45] !font-medium !text-[var(--color-text)]">
              {entry.data.subtitle}
            </p>
          )
        }
      </header>
      <CaseToc locale={contentLocale} />
      <Content />
    </Prose>
  </main>
</BaseLayout>

<style>
  .case-hero :global(h1),
  .case-hero__subtitle {
    text-wrap: pretty;
  }

  .case-hero + :global(.breakout),
  .case-hero + :global(.case-toc) + :global(.breakout) {
    margin-block-start: 0;
  }
</style>
