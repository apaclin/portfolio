---
import { Image } from 'astro:assets';
import TranslationNotice from './TranslationNotice.astro';
import matchpointCover from '../assets/project-covers/matchpoint.webp';
import tTaxiCover from '../assets/project-covers/t-taxi.webp';
import laneoCover from '../assets/project-covers/laneo.png';
import onlineCinemaCover from '../assets/project-covers/online-cinema.webp';
import architectureStudioCover from '../assets/project-covers/architecture-studio.webp';
import radixCover from '../assets/pet-projects/radix-cover.png';
import portrait from '../assets/profile/alexander-paklin.jpg';

interface ProjectItem {
  title: string;
  href?: string;
  external?: boolean;
  image?: ImageMetadata;
  imageAlt?: string;
  comingSoon?: boolean;
}

interface ProjectSection {
  title: string;
  items: ProjectItem[];
}

interface Props {
  fallbackContentLocale?: 'ru' | 'en';
}

const { fallbackContentLocale } = Astro.props as Props;

const contactLinks = [
  {
    label: 'Резюме',
    href: 'https://docs.google.com/document/d/1YNz4EceIuJb3XWb2HBYgc6JKpGGa0Thoesb_y2Jztkc/edit?usp=sharing',
    external: true,
  },
  {
    label: 'Telegram',
    href: 'http://t.me/apaclin',
    external: true,
  },
  {
    label: 'Email',
    href: 'mailto:apaclin@gmail.com',
  },
];

const sections: ProjectSection[] = [
  {
    title: 'B2B SaaS',
    items: [
      {
        title: 'Matchpoint',
        href: '/cases/matchpoint',
        image: matchpointCover,
        imageAlt: 'Интерфейс Matchpoint на светлом мокапе',
      },
      {
        title: 'Т-Такси',
        href: '/cases/t-taxi',
        image: tTaxiCover,
        imageAlt: 'Темный мониторинг Т-Такси на экране',
      },
      {
        title: 'Laneo',
        href: '/cases/laneo',
        image: laneoCover,
        imageAlt: 'Интерфейс Laneo CRM на светлом мокапе',
        comingSoon: true,
      },
    ],
  },
  {
    title: 'Проекты на Behance',
    items: [
      {
        title: 'Онлайн-кинотеатр',
        href: '/cases/online-cinema',
        image: onlineCinemaCover,
        imageAlt: 'Мобильный интерфейс онлайн-кинотеатра Filmaze',
      },
      {
        title: 'Сайт архитектурной студии',
        href: '/cases/architecture-studio',
        image: architectureStudioCover,
        imageAlt: 'Сайт архитектурной студии Bergstrom на ноутбуке',
      },
    ],
  },
  {
    title: 'Pet-проекты',
    items: [
      {
        title: 'Генератор тоновых растяжек',
        href: 'https://www.figma.com/community/plugin/1636766593436362521',
        external: true,
        image: radixCover,
        imageAlt: 'Обложка плагина Radix Colors to Variables',
      },
    ],
  },
];
---

<main class="mx-auto w-full max-w-[72rem] px-5 py-16 sm:px-6 lg:px-8">
  {fallbackContentLocale && <TranslationNotice contentLocale={fallbackContentLocale} />}

  <div class="mt-4 lg:flex lg:items-start lg:gap-16">
    <section class="lg:w-72 lg:shrink-0 lg:sticky lg:top-16">
      <Image
        src={portrait}
        alt="Александр Паклин"
        widths={[96, 112, 192, 224]}
        sizes="(min-width: 40rem) 112px, 96px"
        class="mb-5 h-24 w-24 rounded-lg border border-[var(--color-border)] object-cover sm:h-28 sm:w-28"
        loading="eager"
        decoding="async"
      />
      <p class="mb-3 text-sm text-[var(--color-text-muted)]">Product / UX Designer</p>
      <h1 class="text-3xl font-semibold tracking-normal text-[var(--color-text)]">
        Александр Паклин
      </h1>
      <p class="mt-4 leading-7 text-[var(--color-text-muted)]">
        Проектирую сложные B2B веб-сервисы: от сценариев и структуры данных до UI,
        прототипов и дизайн-систем.
      </p>
      <p class="mt-5 flex flex-wrap gap-x-2 gap-y-1 text-sm text-[var(--color-text-muted)]">
        {
          contactLinks.map((link, index) => (
            <>
              {index > 0 && <span aria-hidden="true">·</span>}
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noreferrer' : undefined}
                class="underline-offset-4 hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
              >
                {link.label}
              </a>
            </>
          ))
        }
      </p>
    </section>

    <div class="mt-12 lg:mt-0 lg:flex-1 space-y-14">
    {
      sections.map((section) => (
        <section aria-labelledby={`section-${section.title}`}>
          <h2
            id={`section-${section.title}`}
            class="text-xl font-semibold tracking-normal text-[var(--color-text)]"
          >
            {section.title}
          </h2>
          <div class="mt-6 grid gap-8 sm:grid-cols-2">
            {section.items.map((item) => (
              <article aria-disabled={item.comingSoon ? 'true' : undefined}>
                {
                  item.comingSoon ? (
                    <div class="relative aspect-video w-full overflow-hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
                      {
                        item.image ? (
                          <Image
                            src={item.image}
                            alt={item.imageAlt ?? item.title}
                            widths={[480, 720, 960]}
                            sizes="(min-width: 64rem) 350px, (min-width: 40rem) 50vw, calc(100vw - 2.5rem)"
                            class="h-full w-full scale-[1.08] object-cover opacity-65 blur-[7px]"
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <div class="h-full w-full bg-black opacity-65 blur-[3px]"></div>
                        )
                      }
                      <div class="absolute inset-0 grid place-items-center bg-white/35">
                        <span class="rounded-full border border-white/60 bg-white/70 px-3 py-1 text-xs font-semibold text-[var(--color-text)] shadow-sm backdrop-blur">
                          Coming Soon
                        </span>
                      </div>
                    </div>
                  ) : item.href ? (
                    <a
                      href={item.href}
                      target={item.external ? '_blank' : undefined}
                      rel={item.external ? 'noreferrer' : undefined}
                      aria-label={`Open ${item.title}`}
                      class="block overflow-hidden rounded-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
                    >
                      {
                        item.image ? (
                          <Image
                            src={item.image}
                            alt={item.imageAlt ?? item.title}
                            widths={[480, 720, 960]}
                            sizes="(min-width: 64rem) 350px, (min-width: 40rem) 50vw, calc(100vw - 2.5rem)"
                            class="aspect-video w-full rounded-lg border border-[var(--color-border)] object-cover"
                            loading="lazy"
                            decoding="async"
                          />
                        ) : (
                          <div class="aspect-video w-full rounded-lg bg-black"></div>
                        )
                      }
                    </a>
                  ) : (
                    <div class="aspect-video w-full rounded-lg bg-black"></div>
                  )
                }
                <h3
                  class:list={[
                    'mt-3 text-base font-medium',
                    item.comingSoon ? 'text-[var(--color-text-faint)]' : 'text-[var(--color-text)]',
                  ]}
                >
                  {
                    item.comingSoon ? (
                      item.title
                    ) : item.href ? (
                      <a
                        href={item.href}
                        target={item.external ? '_blank' : undefined}
                        rel={item.external ? 'noreferrer' : undefined}
                        class="underline-offset-4 hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
                      >
                        {item.title}
                      </a>
                    ) : (
                      item.title
                    )
                  }
                </h3>
              </article>
            ))}
          </div>
        </section>
      ))
    }
    </div>
  </div>
</main>
