---
// Единый паттерн обычной картинки кейса для MDX, на astro:assets.
// <Picture> даёт AVIF + WebP (+ srcset, width/height без CLS, lazy). Zoom через
// общий Lightbox (по умолчанию вкл) — для увеличения генерируем hi-res webp.
import { Picture, getImage } from 'astro:assets';

interface Props {
  /** Импортированное изображение из src/assets (ImageMetadata). */
  src: ImageMetadata;
  alt: string;
  caption?: string;
  /** Делать ли картинку увеличиваемой по клику (по умолчанию да). */
  zoomable?: boolean;
  /** sizes для srcset (по умолчанию — под колонку 60rem / full-bleed). */
  sizes?: string;
  /** Логическая (CSS) ширина макета для лайтбокса: 1440 / 1920. По умолч. 1440. */
  maxWidth?: number;
}
const {
  src,
  alt,
  caption,
  zoomable = true,
  sizes = '(min-width: 64rem) 960px, 100vw',
  maxWidth = 1440,
} = Astro.props as Props;

const widths = [480, 800, 1200, 1600].filter((w) => w < src.width).concat(src.width);

// Для лайтбокса — полное натуральное разрешение (1:1), webp.
const zoom = zoomable
  ? await getImage({ src, width: src.width, format: 'webp' })
  : null;
---

<figure class="case-image full-bleed not-prose mx-auto my-8 max-w-[60rem] px-5 sm:px-6">
  {
    zoomable && zoom ? (
      <button
        type="button"
        data-zoomable
        data-zoom-src={zoom.src}
        data-zoom-alt={alt}
        data-max-width={maxWidth}
        aria-label={`Enlarge image: ${alt}`}
      >
        <Picture src={src} alt={alt} formats={['avif', 'webp']} widths={widths} sizes={sizes} loading="lazy" decoding="async" />
      </button>
    ) : (
      <Picture src={src} alt={alt} formats={['avif', 'webp']} widths={widths} sizes={sizes} loading="lazy" decoding="async" />
    )
  }
  {caption && <figcaption class="case-image__caption">{caption}</figcaption>}
</figure>

<style>
  .case-image :global(picture) {
    display: block;
  }
  /* Натуральный размер, по центру по горизонтали, без upscale.
     max-width:100% — если картинка шире колонки, ужимается до неё (не вылезает). */
  .case-image :global(img) {
    display: block;
    max-width: 100%;
    width: auto;
    height: auto;
    margin-inline: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
  }
  .case-image__caption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }
</style>
