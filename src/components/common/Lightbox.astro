---
// Общий лайтбокс для просмотра изображений. Нативный <dialog> + showModal()
// даёт top-layer, ::backdrop, Esc, focus-trap, inert фона и возврат фокуса —
// без библиотек. Подключается ОДИН раз в BaseLayout. Открывается делегированным
// кликом по любому [data-zoomable] на странице. Картинку грузит только при
// открытии → нулевое влияние на начальную загрузку.
---

<dialog
  class="lightbox"
  aria-label="Image viewer"
  data-astro-transition-persist="lightbox"
>
  <div class="lightbox__media"></div>
  <button type="button" class="lightbox__nav lightbox__nav--prev is-hidden" aria-label="Previous image" disabled>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m15 18-6-6 6-6" />
    </svg>
  </button>
  <button type="button" class="lightbox__nav lightbox__nav--next is-hidden" aria-label="Next image" disabled>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m9 18 6-6-6-6" />
    </svg>
  </button>
  <button type="button" class="lightbox__close" aria-label="Close" autofocus>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6 6 18M6 6l12 12" />
    </svg>
  </button>
</dialog>

<style>
  .lightbox {
    width: 100%;
    height: 100%;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    border: 0;
    padding: 0;
    background: transparent;
    overflow: hidden;
  }
  .lightbox::backdrop {
    background-color: color-mix(in oklab, var(--color-text) 80%, transparent);
  }
  .lightbox__media {
    position: absolute;
    inset: 0;
    overflow: auto; /* картинка больше вьюпорта → скролл по обеим осям */
    display: grid;
    place-items: safe center; /* центр, если влезает; иначе скролл от края, без обрезки */
    padding: clamp(1rem, 4vw, 3rem);
    box-sizing: border-box;
  }
  /* В лайтбоксе клик по изображению закрывает просмотр, поэтому над картинкой
     показываем zoom-out. Если пользователь именно тащит переполненный макет,
     временно показываем grabbing. */
  .lightbox__media > :global(*) {
    cursor: zoom-out;
  }
  .lightbox__media.is-grabbing > :global(*) {
    cursor: grabbing;
  }
  .lightbox__media :global(img),
  .lightbox__media :global(svg) {
    display: block;
    /* Базовое состояние (Fit Width): до логической ширины макета, но не шире
       контейнера и без upscale (width:auto). Физический @2x-файл показывается
       в логическом размере → интерфейсы не «взрывают» верстку. */
    max-width: min(var(--lightbox-lw, 1440px), 100%);
    width: auto;
    height: auto;
    border-radius: 0.5rem;
    background-color: var(--color-bg);
    user-select: none;
    -webkit-user-drag: none; /* не запускать нативный drag картинки */
  }
  .lightbox[data-fit='contain'] .lightbox__media :global(img),
  .lightbox[data-fit='contain'] .lightbox__media :global(svg) {
    max-width: min(var(--lightbox-lw, 100vw), 100%);
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .lightbox__nav,
  .lightbox__close {
    position: fixed;
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
    cursor: pointer;
    transition: opacity 300ms ease;
  }
  .lightbox__nav {
    top: 50%;
    transform: translateY(-50%);
  }
  .lightbox__nav--prev {
    left: clamp(0.75rem, 2vw, 1.25rem);
  }
  .lightbox__nav--next {
    right: clamp(0.75rem, 2vw, 1.25rem);
  }
  .lightbox__nav[disabled],
  .lightbox__nav.is-hidden {
    opacity: 0;
    pointer-events: none;
    cursor: default;
  }
  .lightbox__close {
    top: clamp(0.75rem, 2vw, 1.25rem);
    right: clamp(0.75rem, 2vw, 1.25rem);
  }
  .lightbox__nav:focus-visible,
  .lightbox__close:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }
</style>

{/* Глобальный вид триггера зума (кнопка вокруг изображения) — единый источник. */}
<style is:global>
  button[data-zoomable] {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    border-radius: inherit;
    color: inherit;
    font: inherit;
  }
  button[data-zoomable]:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<script>
  const dialog = document.querySelector<HTMLDialogElement>('.lightbox');
  if (dialog) {
    const media = dialog.querySelector<HTMLElement>('.lightbox__media')!;
    const prevImage = dialog.querySelector<HTMLButtonElement>('.lightbox__nav--prev')!;
    const nextImage = dialog.querySelector<HTMLButtonElement>('.lightbox__nav--next')!;
    const closeButton = dialog.querySelector<HTMLButtonElement>('.lightbox__close')!;
    let logicalWidth = 1440;
    let group: Element[] = [];
    let activeIndex = 0;
    let renderId = 0;
    const preloadedZoom = new Set<string>();

    // is-pannable считается динамически из реального переполнения в текущем
    // состоянии. Если макет не помещается по высоте/ширине, его можно потянуть.
    const prepare = () => {
      const pannable =
        media.scrollWidth > media.clientWidth + 1 ||
        media.scrollHeight > media.clientHeight + 1;
      media.classList.toggle('is-pannable', pannable);
    };

    const syncLightboxNav = () => {
      const hasGroup = group.length > 1;
      const updateButton = (
        button: HTMLButtonElement,
        isDisabled: boolean
      ) => {
        button.disabled = isDisabled;
        button.classList.toggle('is-hidden', !hasGroup || isDisabled);
      };

      updateButton(prevImage, !hasGroup || activeIndex <= 0);
      updateButton(nextImage, !hasGroup || activeIndex >= group.length - 1);
    };

    const waitForImage = async (img: HTMLImageElement) => {
      if (!img.complete) {
        await new Promise<void>((resolve) => {
          img.addEventListener('load', () => resolve(), { once: true });
          img.addEventListener('error', () => resolve(), { once: true });
        });
      }
      await img.decode?.().catch(() => undefined);
    };

    const preloadZoomImage = (trigger: Element | undefined) => {
      const src = trigger?.getAttribute('data-zoom-src');
      if (!src || preloadedZoom.has(src)) return;
      preloadedZoom.add(src);

      const img = new Image();
      img.decoding = 'async';
      img.src = src;
      void img.decode?.().catch(() => undefined);
    };

    const preloadGroupAround = (index: number) => {
      if (group.length <= 1) return;
      [index + 1, index - 1, ...group.map((_, i) => i)]
        .filter((i, pos, list) => i >= 0 && i < group.length && list.indexOf(i) === pos)
        .forEach((i, pos) => {
          window.setTimeout(() => preloadZoomImage(group[i]), pos * 140);
        });
    };

    const syncSourceCarousel = () => {
      const trigger = group[activeIndex];
      const carousel = trigger?.closest('.carousel');
      const track = carousel?.querySelector<HTMLElement>('.carousel__track');
      if (!carousel || !track) return;

      track.scrollTo({
        left: activeIndex * track.clientWidth,
        behavior: 'auto',
      });
      carousel.dispatchEvent(new CustomEvent('carousel:sync'));
    };

    const render = async (trigger: Element) => {
      const currentRender = ++renderId;
      media.classList.remove('is-pannable', 'is-grabbing');
      media.scrollTo({ left: 0, top: 0, behavior: 'auto' });
      syncLightboxNav();
      preloadGroupAround(activeIndex);

      // Логическая (CSS) ширина макета: из data-max-width, иначе 1440.
      logicalWidth = parseInt(trigger.getAttribute('data-max-width') ?? '', 10) || 1440;
      dialog.style.setProperty('--lightbox-lw', `${logicalWidth}px`);
      dialog.dataset.fit = trigger.getAttribute('data-lightbox-fit') ?? 'width';

      let img: HTMLImageElement | null = null;
      let nextNode: HTMLElement | SVGElement | null = null;
      const src = trigger.getAttribute('data-zoom-src');
      if (src) {
        // Растровое изображение: hi-res файл, но показываем в логическом размере.
        img = document.createElement('img');
        img.src = src;
        img.alt = trigger.getAttribute('data-zoom-alt') ?? '';
        img.decoding = 'async';
        img.draggable = false; // не запускать нативный drag картинки — мешает pan
        await waitForImage(img);
        nextNode = img;
      } else {
        // SVG-диаграмма (opt-in): клонируем svg из триггера в натуральном размере.
        const svg = trigger.querySelector('svg');
        if (svg) {
          const clone = svg.cloneNode(true) as SVGElement;
          // Если у svg нет явных width/height — берём натуральный размер из viewBox.
          if (!clone.getAttribute('width') || !clone.getAttribute('height')) {
            const vb = (svg.getAttribute('viewBox') ?? '').split(/[\s,]+/).map(Number);
            if (vb.length === 4) {
              clone.setAttribute('width', String(vb[2]));
              clone.setAttribute('height', String(vb[3]));
            }
          }
          nextNode = clone;
        }
      }

      if (currentRender !== renderId || !nextNode) return;

      media.replaceChildren(nextNode);
      syncLightboxNav();
      if (!dialog.open) {
        dialog.showModal();
      }
      document.body.style.overflow = 'hidden'; // блокируем фоновый скролл

      // После раскладки пересчитываем, есть ли реальное переполнение для pan.
      const afterLayout = () => prepare();
      requestAnimationFrame(afterLayout);
    };

    const open = (trigger: Element) => {
      const carousel = trigger.closest('.carousel');
      group = carousel
        ? Array.from(carousel.querySelectorAll('[data-zoomable]'))
        : [trigger];
      activeIndex = Math.max(0, group.indexOf(trigger));

      void render(group[activeIndex]);
    };

    // Делегированный клик по любому триггеру на странице.
    document.addEventListener('click', (event) => {
      const trigger = (event.target as Element).closest('[data-zoomable]');
      if (trigger) {
        event.preventDefault();
        open(trigger);
      }
    });

    const goToImage = (dir: number) => {
      const nextIndex = activeIndex + dir;
      if (nextIndex < 0 || nextIndex >= group.length) return;
      activeIndex = nextIndex;
      syncLightboxNav();
      preloadGroupAround(activeIndex);
      void render(group[activeIndex]);
    };

    prevImage.addEventListener('click', (event) => {
      event.stopPropagation();
      goToImage(-1);
    });
    nextImage.addEventListener('click', (event) => {
      event.stopPropagation();
      goToImage(1);
    });
    closeButton.addEventListener('click', (event) => {
      event.stopPropagation();
      dialog.close();
    });

    // Drag/pan «как в Figma/Notion»: тянем за саму картинку → двигаем скролл.
    // Тач не трогаем — там нативный скролл/свайп. Картинка остаётся 1:1.
    let armed = false; // указатель нажат на картинке, но драг ещё не начался
    let panning = false;
    let startX = 0;
    let startY = 0;
    let startLeft = 0;
    let startTop = 0;
    let suppressClick = false;

    media.addEventListener('pointerdown', (event) => {
      if (event.pointerType === 'touch' || event.button !== 0) return;
      if (!media.classList.contains('is-pannable')) return;
      if (!(event.target as Element).closest('.lightbox__media > *')) return; // только по картинке
      armed = true;
      panning = false;
      startX = event.clientX;
      startY = event.clientY;
      startLeft = media.scrollLeft;
      startTop = media.scrollTop;
    });
    media.addEventListener('pointermove', (event) => {
      if (!armed) return;
      const dx = event.clientX - startX;
      const dy = event.clientY - startY;
      // Захватываем указатель ТОЛЬКО при реальном драге (>5px). Иначе простой
      // клик остаётся на картинке (его таргет не переедет на контейнер) → зум.
      if (!panning && Math.abs(dx) + Math.abs(dy) > 5) {
        panning = true;
        media.setPointerCapture(event.pointerId);
        media.classList.add('is-grabbing');
      }
      if (panning) {
        media.scrollLeft = startLeft - dx;
        media.scrollTop = startTop - dy;
      }
    });
    const endPan = (event: PointerEvent) => {
      armed = false;
      if (!panning) return;
      panning = false;
      media.releasePointerCapture?.(event.pointerId);
      media.classList.remove('is-grabbing');
      suppressClick = true; // был драг → клик (зум/закрытие) игнорируем
    };
    media.addEventListener('pointerup', endPan);
    media.addEventListener('pointercancel', endPan);
    media.addEventListener('pointerleave', () => {
      if (!panning) {
        armed = false;
        media.classList.remove('is-grabbing');
      }
    });

    // Клик по картинке или фону закрывает лайтбокс. После pan-драга клик
    // игнорируем, чтобы случайно не закрывать просмотр.
    dialog.addEventListener('click', (event) => {
      if ((event.target as Element).closest('.lightbox__nav, .lightbox__close')) {
        return;
      }
      if (suppressClick) {
        suppressClick = false;
        return;
      }
      const onImage = (event.target as Element).closest('.lightbox__media > *');
      if (onImage) {
        dialog.close();
      } else {
        dialog.close();
      }
    });

    dialog.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        goToImage(-1);
      } else if (event.key === 'ArrowRight') {
        event.preventDefault();
        goToImage(1);
      }
    });

    // Снятие блокировки скролла — на ЛЮБОЙ сценарий закрытия (Esc, кнопка Close,
    // клик по фону через .close()). Событие close у <dialog> покрывает все.
    dialog.addEventListener('close', () => {
      syncSourceCarousel();
      renderId++;
      document.body.style.overflow = '';
      group = [];
      activeIndex = 0;
      syncLightboxNav();
    });
    // Esc и возврат фокуса на триггер обеспечивает сам <dialog>.
  }
</script>
