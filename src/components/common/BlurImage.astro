---
// Responsive image frame for the homepage. It intentionally avoids LQIP:
// images load as sharp frames without a placeholder effect.
import { Image } from 'astro:assets';
import { cappedImageWidths } from '../../lib/images';
import { resolveImageAsset } from '../../lib/assets';

interface Props {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
  /** Классы рамки-frame: размеры, border, radius, отступы. */
  class?: string;
  /** Доп. классы для <img>. */
  imgClass?: string;
  /** Приоритетная загрузка (above-the-fold): eager + fetchpriority=high. */
  eager?: boolean;
}

const {
  src: source,
  alt,
  widths = [480, 720, 960],
  sizes,
  class: frameClass,
  imgClass,
  eager = false,
} = Astro.props as Props;

const src = resolveImageAsset(source, 'BlurImage.astro');
const responsiveWidths = cappedImageWidths(src.width, widths);
---

<div class:list={['image-frame', frameClass]}>
  <Image
    src={src}
    alt={alt}
    widths={responsiveWidths}
    sizes={sizes}
    format="webp"
    class:list={['frame-img', imgClass]}
    loading={eager ? 'eager' : 'lazy'}
    fetchpriority={eager ? 'high' : 'auto'}
    decoding="async"
  />
</div>

<style>
  .image-frame {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-subtle);
  }
  /* .frame-img висит на <img> из <Image> — без scoped-cid этого компонента,
     поэтому селекторы глобальные. */
  :global(.frame-img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
