---
import { useTranslations } from '../../i18n/ui';
import type { CaseLocale } from '../../lib/cases';

interface Props {
  contentLocale: CaseLocale;
}

// Текст баннера — в локали страницы (на /ru/ это русский).
// Намеренно НЕ принимаем lang пропом: баннер всегда на языке посетителя.
const { contentLocale } = Astro.props as Props;
const t = useTranslations(Astro.currentLocale);
const key = contentLocale === 'ru' ? 'notice.fallbackToRu' : 'notice.fallbackToEn';
---

<aside
  role="note"
  class="mb-6 rounded-md border border-[var(--color-border)] bg-[var(--color-bg-subtle)] px-4 py-3 text-sm text-[var(--color-text-muted)]"
>
  {t(key)}
</aside>
