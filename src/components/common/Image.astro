---
// Единый паттерн обычной картинки кейса для MDX, на astro:assets.
// <Picture> даёт AVIF + WebP fallback (srcset, width/height без CLS, lazy). Zoom через
// общий Lightbox (по умолчанию вкл) — для увеличения генерируем hi-res webp.
import { Picture, getImage } from 'astro:assets';
import { cappedImageWidths, cappedZoomWidth } from '../../lib/images';
import { resolveImageAsset } from '../../lib/assets';

interface Props {
  /** Импортированное изображение из src/assets (ImageMetadata). */
  src: ImageMetadata | string;
  alt: string;
  caption?: string;
  class?: string;
  /** Делать ли картинку увеличиваемой по клику (по умолчанию да). */
  zoomable?: boolean;
  variant?: 'case' | 'inline';
  /** sizes для srcset (по умолчанию — под 912px UI-кадр внутри 960px figure). */
  sizes?: string;
  widths?: number[];
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  fetchpriority?: 'high' | 'low' | 'auto';
  quality?: number;
  /** Логическая (CSS) ширина макета для лайтбокса: 1440 / 1920. По умолч. 1440. */
  maxWidth?: number;
  /**
   * Как лайтбокс вписывает макет. 'contain' (по умолч.) — целиком на экран.
   * 'width' — во всю логическую ширину с вертикальным скроллом и pan; нужен
   * высоким экранам, которые в contain ужимаются до половины вьюпорта.
   */
  lightboxFit?: 'contain' | 'width';
}
const {
  src: source,
  alt,
  caption,
  class: className,
  zoomable = true,
  variant = 'case',
  sizes = '(min-width: 64rem) 912px, calc(100vw - 3rem)',
  widths: requestedWidths,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority = 'auto',
  quality = 90,
  maxWidth = 1440,
  lightboxFit = 'contain',
} = Astro.props as Props;

const src = resolveImageAsset(source, 'Image.astro');
const widths = cappedImageWidths(src.width, requestedWidths);

// Для лайтбокса — до 2× логической ширины, без бесполезного full-resolution export.
const zoom = zoomable
  ? await getImage({
      src,
      width: cappedZoomWidth(src.width, maxWidth),
      format: 'webp',
      quality,
    })
  : null;
---

<figure
  class:list={[
    'case-image not-prose',
    variant === 'case' && 'full-bleed mx-auto max-w-[60rem] px-5 sm:px-6',
    variant === 'inline' && 'case-image--inline m-0 w-full',
  ]}
>
  {
    zoomable && zoom ? (
      <button
        type="button"
        data-zoomable
        data-zoom-src={zoom.src}
        data-zoom-alt={alt}
        data-max-width={maxWidth}
        data-lightbox-fit={lightboxFit}
        aria-label={`Enlarge image: ${alt}`}
      >
        <Picture
          src={src}
          alt={alt}
          formats={['avif']}
          fallbackFormat="webp"
          widths={widths}
          sizes={sizes}
          quality={quality}
          class={className}
          loading={loading}
          decoding={decoding}
          fetchpriority={fetchpriority}
        />
      </button>
    ) : (
      <Picture
        src={src}
        alt={alt}
        formats={['avif']}
        fallbackFormat="webp"
        widths={widths}
        sizes={sizes}
        quality={quality}
        class={className}
        loading={loading}
        decoding={decoding}
        fetchpriority={fetchpriority}
      />
    )
  }
  {caption && <figcaption class="case-image__caption" set:html={caption} />}
</figure>

<style>
  .case-image {
    margin-block-start: var(--space-media-before);
    padding-block-end: var(--space-media-after);
  }
  :global(.breakout) .case-image {
    margin-block-start: 0;
    padding-block-end: 0;
  }
  .case-image--inline {
    margin-block-start: 0;
    padding-block-end: 0;
  }
  .case-image :global(picture) {
    display: block;
    width: 100%;
  }
  .case-image :global([data-zoomable]) {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
  }
  /* UI-кадры занимают предусмотренные 912px внутри 960px figure. */
  .case-image :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin-inline: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
  }
  .case-image:not(.case-image--inline) :global(img) {
    width: 100%;
  }
  /* Inline-медиа сохраняют натуральную ширину и не апскейлятся. */
  .case-image--inline :global(img) {
    width: auto;
  }
  .case-image__caption {
    margin-top: 0.5rem;
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }
</style>
