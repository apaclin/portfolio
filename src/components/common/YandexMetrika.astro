---
// Счётчик Яндекс.Метрики. Подключается только в прод-сборке, чтобы визиты
// с localhost не попадали в статистику.
const counterId = 110810904;
const isEnabled = import.meta.env.PROD;
---

{
  isEnabled && (
    <Fragment>
      <script is:inline define:vars={{ counterId }}>
        (function (m, e, t, r, i, k, a) {
          m[i] =
            m[i] ||
            function () {
              (m[i].a = m[i].a || []).push(arguments);
            };
          m[i].l = 1 * new Date();
          for (var j = 0; j < document.scripts.length; j++) {
            if (document.scripts[j].src === r) {
              return;
            }
          }
          k = e.createElement(t);
          a = e.getElementsByTagName(t)[0];
          k.async = 1;
          k.src = r;
          a.parentNode.insertBefore(k, a);
        })(
          window,
          document,
          'script',
          'https://mc.yandex.ru/metrika/tag.js?id=' + counterId,
          'ym',
        );

        ym(counterId, 'init', {
          ssr: true,
          webvisor: true,
          clickmap: true,
          ecommerce: 'dataLayer',
          referrer: document.referrer,
          url: location.href,
          accurateTrackBounce: true,
          trackLinks: true,
        });

        // ClientRouter меняет страницы без перезагрузки, поэтому просмотры
        // после первого нужно отправлять вручную. astro:after-swap не
        // срабатывает на первой загрузке — двойного хита не будет.
        var ymPrevUrl = location.href;
        document.addEventListener('astro:after-swap', function () {
          var referrer = ymPrevUrl;
          ymPrevUrl = location.href;
          ym(counterId, 'hit', location.href, {
            title: document.title,
            referer: referrer,
          });
        });
      </script>
      <noscript>
        <div>
          <img
            src={`https://mc.yandex.ru/watch/${counterId}`}
            style="position:absolute; left:-9999px;"
            alt=""
          />
        </div>
      </noscript>
    </Fragment>
  )
}
