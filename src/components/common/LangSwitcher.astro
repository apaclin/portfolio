---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations } from '../../i18n/ui';
import { stripLocale } from '../../i18n/paths';
import { alternateLocale, resolveLocale } from '../../lib/i18n';

const current = resolveLocale(Astro.currentLocale);
const other = alternateLocale(current);

// «Логический путь» без языкового префикса (общий хелпер).
const basePath = stripLocale(Astro.url.pathname);

// Строим ссылку на ТУ ЖЕ страницу в другой локали.
// getRelativeLocaleUrl сам добавит/уберёт префикс по конфигу i18n.
const href = getRelativeLocaleUrl(other, basePath);

const t = useTranslations(current);
---

<a href={href} hreflang={other} class="text-sm underline underline-offset-4">
  {t('action.switchLang')}
</a>
