---
interface Props {
  maxWidth?: string;
  /** Minimum readable content width. Wider content pans instead of shrinking. */
  minWidth?: string;
  /** Center media in the viewport, or align diagrams to the prose column. */
  align?: 'center' | 'content';
  /** Disable only when a child needs viewport-relative sticky positioning. */
  scroll?: boolean;
}

const {
  maxWidth = '1100px',
  minWidth = '0px',
  align = 'center',
  scroll = true,
} = Astro.props as Props;
---

<div
  class:list={[
    'breakout relative left-1/2 w-screen -translate-x-1/2',
    align === 'content' && 'breakout--content',
    scroll && 'overflow-x-auto overscroll-x-contain',
  ]}
>
  <div
    class="breakout__inner"
    style={`--breakout-min:${minWidth};--breakout-max:${maxWidth}`}
  >
    <slot />
  </div>
</div>

<style>
  .breakout {
    margin-block-start: var(--space-media-before);
    padding-block-end: var(--space-media-after);
    scrollbar-width: thin;
  }
  .breakout__inner {
    width: clamp(var(--breakout-min), calc(100% - 2rem), var(--breakout-max));
    margin-inline: auto;
  }
  .breakout--content .breakout__inner {
    --content-start: max(1.25rem, calc((100vw - 42rem) / 2));
    width: clamp(
      var(--breakout-min),
      calc(100% - var(--content-start) - 1.25rem),
      var(--breakout-max)
    );
    margin-inline: var(--content-start) 0;
  }
  .breakout :global(.case-image),
  .breakout :global(.carousel) {
    margin-block-start: 0;
    padding-block-end: 0;
  }
  .breakout :global(svg) {
    display: block;
    height: auto;
  }
  .breakout:not(.breakout--content) :global(svg) {
    margin-inline: auto;
  }
</style>
