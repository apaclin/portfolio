---
import Icon from './icons/Icon.astro';

interface Props {
  variant?: 'article' | 'floating';
  href?: string;
  label?: string;
  class?: string;
}

const {
  variant = 'article',
  href = '/',
  label = 'Все проекты',
  class: className,
} = Astro.props as Props;
---

<a
  href={href}
  class:list={[
    'case-nav',
    'not-prose',
    variant === 'floating' ? 'case-nav--floating' : 'case-nav--article',
    className,
  ]}
  aria-label={label}
>
  <Icon name="chevron-left" size={16} class="case-nav__icon" />
  <span class="case-nav__label">{label}</span>
</a>

<script>
  const floatingNavs = Array.from(document.querySelectorAll<HTMLElement>('.case-nav--floating'));

  if (floatingNavs.length > 0) {
    let lastY = window.scrollY;
    let ticking = false;
    const threshold = 8;

    const setHidden = (hidden: boolean) => {
      floatingNavs.forEach((nav) => {
        nav.classList.toggle('is-hidden', hidden);
      });
    };

    const update = () => {
      const currentY = window.scrollY;
      const delta = currentY - lastY;

      if (currentY <= 24) {
        setHidden(false);
      } else if (Math.abs(delta) >= threshold) {
        setHidden(delta > 0);
        lastY = currentY;
      }

      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );

    floatingNavs.forEach((nav) => {
      nav.addEventListener('focusin', () => setHidden(false));
      nav.addEventListener('mouseenter', () => setHidden(false));
    });
  }
</script>

<style>
  @font-face {
    font-family: "Inter";
    font-style: normal;
    font-weight: 100 900;
    font-display: swap;
    src: url("/fonts/inter-latin.woff2") format("woff2");
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA,
      U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC, U+2122, U+2191,
      U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }

  @font-face {
    font-family: "Inter";
    font-style: normal;
    font-weight: 100 900;
    font-display: swap;
    src: url("/fonts/inter-cyrillic.woff2") format("woff2");
    unicode-range: U+0301, U+0400-045F, U+0490-0491, U+04B0-04B1, U+2116;
  }

  @font-face {
    font-family: "Inter Fallback";
    src: local("Arial");
    ascent-override: 90.44%;
    descent-override: 22.52%;
    line-gap-override: 0%;
    size-adjust: 107.12%;
  }

  .case-nav {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    gap: 0.375rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.25rem;
    font-family: "Inter", "Inter Fallback", ui-sans-serif, system-ui, -apple-system, "Segoe UI",
      Roboto, Helvetica, Arial, sans-serif;
    text-decoration: none;
    transition:
      color 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease,
      opacity 160ms ease,
      transform 220ms ease;
  }

  .case-nav__icon {
    flex: 0 0 auto;
  }

  .case-nav--article {
    margin: 0 0 2.5rem;
    padding: 0;
    color: var(--color-text-muted);
  }

  .case-nav--article:hover {
    color: var(--color-text);
  }

  .case-nav--article:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 4px;
  }

  .case-nav--floating {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 50;
    padding: 0.5rem 0.75rem 0.5rem 0.625rem;
    border: 1px solid rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.72);
    color: #37352f;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
  }

  .case-nav--floating.is-hidden {
    pointer-events: none;
    opacity: 0;
    transform: translateY(calc(-100% - 1.5rem));
  }

  .case-nav--floating:hover {
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.92);
  }

  .case-nav--floating:active {
    transform: translateY(1px);
  }

  .case-nav--floating:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.95);
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .case-nav--article {
      margin-bottom: 2rem;
    }

    .case-nav--floating {
      top: 0.75rem;
      left: 0.75rem;
      padding: 0.5rem 0.625rem 0.5rem 0.5rem;
    }
  }
</style>
