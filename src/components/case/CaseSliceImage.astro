---
import { Picture } from 'astro:assets';
import { cappedImageWidths, caseSliceWidths } from '../../lib/images';

interface Props {
  src: ImageMetadata;
  alt: string;
  eager?: boolean;
  sizes?: string;
}

const { src, alt, eager = false, sizes = '100vw' } = Astro.props as Props;

const widths = cappedImageWidths(src.width, caseSliceWidths);
---

<Picture
  pictureAttributes={{ class: 'case-slice' }}
  src={src}
  alt={alt}
  formats={['avif']}
  fallbackFormat="webp"
  widths={widths}
  sizes={sizes}
  quality={90}
  loading={eager ? 'eager' : 'lazy'}
  decoding={eager ? 'sync' : 'async'}
  fetchpriority={eager ? 'high' : 'auto'}
/>

<style>
  :global(.case-slice) {
    display: block;
    width: 100%;
  }
</style>
