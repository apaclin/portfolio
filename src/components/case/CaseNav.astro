---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Icon from '../icons/Icon.astro';
import { useTranslations } from '../../i18n/ui';
import { resolveLocale, type Locale } from '../../lib/i18n';

interface Props {
  variant?: 'article' | 'floating';
  reveal?: 'on-scroll' | 'after-article';
  /**
   * Локаль СТРАНИЦЫ (из URL), а не контента: на /ru/cases/* с англоязычным
   * фоллбэком кнопка всё равно должна быть русской и вести на /ru/.
   * По умолчанию берём Astro.currentLocale.
   */
  locale?: Locale;
  href?: string;
  label?: string;
  class?: string;
}

const {
  variant = 'article',
  reveal = 'on-scroll',
  locale,
  href,
  label,
  class: className,
} = Astro.props as Props;

// Ссылка и подпись выводятся из локали, чтобы кнопка «назад» никогда не
// уводила на другой язык. Явные href/label остаются как переопределение.
const navLocale = locale ?? resolveLocale(Astro.currentLocale);
const t = useTranslations(navLocale);
const navHref = href ?? getRelativeLocaleUrl(navLocale, '');
const navLabel = label ?? t('action.allProjects');
---

<a
  href={navHref}
  class:list={[
    'case-nav',
    'not-prose',
    variant === 'floating' ? 'case-nav--floating' : 'case-nav--article',
    variant === 'floating' && reveal === 'after-article' ? 'is-hidden' : undefined,
    className,
  ]}
  data-case-nav={variant}
  data-reveal={variant === 'floating' ? reveal : undefined}
  aria-hidden={variant === 'floating' && reveal === 'after-article' ? 'true' : undefined}
  aria-label={navLabel}
  tabindex={variant === 'floating' && reveal === 'after-article' ? '-1' : undefined}
>
  <Icon name="chevron-left" size={16} class="case-nav__icon" />
  <span class="case-nav__label">{navLabel}</span>
</a>

<script>
  let activeFloatingNavs: HTMLElement[] = [];
  let cleanupCaseNav: (() => void) | undefined;

  const initCaseNav = () => {
    const floatingNavs = Array.from(
      document.querySelectorAll<HTMLElement>('.case-nav--floating'),
    );

    const isSamePage =
      floatingNavs.length === activeFloatingNavs.length &&
      floatingNavs.every((nav, index) => nav === activeFloatingNavs[index]);
    if (isSamePage) return;

    cleanupCaseNav?.();
    cleanupCaseNav = undefined;
    activeFloatingNavs = floatingNavs;

    if (floatingNavs.length === 0) return;

    const controller = new AbortController();
    const { signal } = controller;
    const cleanup = () => {
      controller.abort();
      if (activeFloatingNavs === floatingNavs) activeFloatingNavs = [];
      if (cleanupCaseNav === cleanup) cleanupCaseNav = undefined;
    };
    cleanupCaseNav = cleanup;
    document.addEventListener('astro:before-swap', cleanup, { once: true, signal });

    floatingNavs.forEach((nav) => {
      nav.dataset.caseNavReady = 'true';
    });

    const sourceNav = document.querySelector<HTMLElement>('.case-nav--article');
    const afterArticleNavs = floatingNavs.filter((nav) => nav.dataset.reveal === 'after-article');
    const scrollNavs = floatingNavs.filter((nav) => nav.dataset.reveal !== 'after-article');
    let lastY = window.scrollY;
    let ticking = false;
    let sourceTicking = false;
    const threshold = 8;

    const setHidden = (navs: HTMLElement[], hidden: boolean) => {
      navs.forEach((nav) => {
        nav.classList.toggle('is-hidden', hidden);
        nav.toggleAttribute('aria-hidden', hidden);
        nav.tabIndex = hidden ? -1 : 0;
      });
    };

    const update = () => {
      const currentY = window.scrollY;
      const delta = currentY - lastY;

      if (currentY <= 24) {
        setHidden(scrollNavs, false);
      } else if (Math.abs(delta) >= threshold) {
        setHidden(scrollNavs, delta > 0);
        lastY = currentY;
      }

      ticking = false;
    };

    const updateFromSource = () => {
      if (sourceNav) {
        const sourceRect = sourceNav.getBoundingClientRect();
        setHidden(afterArticleNavs, sourceRect.bottom >= 0);
      }

      sourceTicking = false;
    };

    const requestSourceUpdate = () => {
      if (!sourceTicking) {
        window.requestAnimationFrame(() => {
          if (!signal.aborted) updateFromSource();
        });
        sourceTicking = true;
      }
    };

    if (scrollNavs.length > 0) {
      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              if (!signal.aborted) update();
            });
            ticking = true;
          }
        },
        { passive: true, signal },
      );
    }

    if (afterArticleNavs.length > 0 && sourceNav) {
      updateFromSource();
      window.addEventListener('scroll', requestSourceUpdate, { passive: true, signal });
      window.addEventListener('resize', requestSourceUpdate, { signal });
    }

    floatingNavs.forEach((nav) => {
      nav.addEventListener('focusin', () => {
        if (nav.dataset.reveal === 'after-article') {
          requestSourceUpdate();
        } else {
          setHidden([nav], false);
        }
      }, { signal });
      nav.addEventListener('mouseenter', () => {
        if (nav.dataset.reveal === 'after-article') {
          requestSourceUpdate();
        } else {
          setHidden([nav], false);
        }
      }, { signal });
    });
  };

  document.addEventListener('astro:page-load', initCaseNav);
  initCaseNav();
</script>

<style>
  .case-nav {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    gap: 0.375rem;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.25rem;
    font-family: "Inter", "Inter Fallback", ui-sans-serif, system-ui, -apple-system, "Segoe UI",
      Roboto, Helvetica, Arial, sans-serif;
    text-decoration: none;
    transition:
      color 160ms ease,
      background-color 160ms ease,
      border-color 160ms ease,
      opacity 160ms ease,
      transform 220ms ease;
  }

  .case-nav__icon {
    flex: 0 0 auto;
  }

  .case-nav--article {
    margin: 0 0 2.5rem;
    padding: 0;
    color: var(--color-text-muted);
  }

  .case-nav--article:hover {
    color: var(--color-text);
  }

  .case-nav--article:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 4px;
  }

  /*
   * Overlay-only variant: a frosted light "back" pill that floats over a case
   * cover as you scroll, so its backdrop changes (dark hero at the top, light UI
   * mockups lower down). It must stay legible on ANY backdrop, so it combines a
   * near-opaque light fill (pops on dark areas) with a dark hairline ring + drop
   * shadow (outlines the silhouette on light areas). Text stays dark for
   * contrast against the fill regardless of what's behind it. Colours derive
   * from design-system tokens (--color-bg white, --color-text charcoal).
   */
  /*
   * NB: fallback-значения в var() обязательны — floating-вариант используется на
   * standalone-страницах (/cases/filmaze, /cases/bergstrom),
   * которые НЕ подключают global.css, поэтому дизайн-токены там не определены.
   * Без фоллбэка color-mix со стёртым var() схлопывается в transparent и кнопка
   * пропадает. #37352f = --color-text, #ffffff = --color-bg.
   */
  .case-nav--floating {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 50;
    padding: 0.5rem 0.75rem 0.5rem 0.625rem;
    border: 1px solid color-mix(in srgb, var(--color-text, #37352f) 10%, transparent);
    background: color-mix(in srgb, var(--color-bg, #ffffff) 86%, transparent);
    color: var(--color-text, #37352f);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-text, #37352f) 8%, transparent),
      0 6px 22px color-mix(in srgb, var(--color-text, #37352f) 30%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
  }

  .case-nav--floating.is-hidden {
    pointer-events: none;
    opacity: 0;
    transform: translateY(calc(-100% - 1.5rem));
  }

  .case-nav--floating:hover {
    border-color: color-mix(in srgb, var(--color-text, #37352f) 16%, transparent);
    background: color-mix(in srgb, var(--color-bg, #ffffff) 96%, transparent);
  }

  .case-nav--floating:active {
    transform: translateY(1px);
  }

  .case-nav--floating:focus-visible {
    outline: 2px solid var(--color-text, #37352f);
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .case-nav--article {
      margin-bottom: 2rem;
    }

    .case-nav--floating {
      top: 0.75rem;
      left: 0.75rem;
      padding: 0.5rem 0.625rem 0.5rem 0.5rem;
    }
  }
</style>
