---
import PublicSvg from '../../common/PublicSvg.astro';

type Lang = 'ru' | 'en';

interface Props {
  lang?: Lang;
}

const { lang = 'ru' } = Astro.props as Props;
const src = `/assets/matchpoint/schemas/flow-as-is.${lang}.svg`;
const alt =
  lang === 'en'
    ? 'Current AP process analysis with failure points'
    : 'Анализ текущего AP-процесса с точками отказа';
---

<PublicSvg src={src} alt={alt} fit="container" />
