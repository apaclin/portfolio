---
// Свой индикатор прокрутки вместо нативного скроллбара.
//
// Нативный убран из раскладки намеренно: он отъедал 11px ширины, борд рисовался
// в 1909 вместо 1920, и браузер пересчитывал картинку — минус четверть резкости
// на тексте. Этот элемент position: fixed, в потоке не участвует, ширину
// контента не трогает, поэтому совпадение 1:1 сохраняется.
//
// Чисто декоративный: прокрутка колесом, клавишами и тачем работает штатно,
// поэтому aria-hidden и pointer-events: none.
---

<div class="case-scroll" aria-hidden="true">
  <div class="case-scroll__thumb"></div>
</div>

<style>
  .case-scroll {
    position: fixed;
    top: 0;
    right: 6px;
    bottom: 0;
    z-index: 20;
    width: 4px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 400ms ease;
  }

  .case-scroll.is-active {
    opacity: 1;
  }

  .case-scroll__thumb {
    position: absolute;
    left: 0;
    width: 100%;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.5);
    /* Борды бывают и светлыми, и тёмными — контур держит полосу читаемой на
       любом фоне. */
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.18);
  }

  @media (prefers-reduced-motion: reduce) {
    .case-scroll {
      transition: none;
    }
  }
</style>

<script>
  const MIN_THUMB = 48;
  const IDLE_MS = 1100;

  function setupScrollIndicator() {
    const bar = document.querySelector<HTMLElement>('.case-scroll');
    const thumb = bar?.querySelector<HTMLElement>('.case-scroll__thumb');
    if (!bar || !thumb) return;

    let idleTimer = 0;
    let frame = 0;

    const render = () => {
      frame = 0;
      const doc = document.documentElement;
      const scrollable = doc.scrollHeight - window.innerHeight;

      // Короткая страница — индикатору нечего показывать.
      if (scrollable <= 0) {
        bar.classList.remove('is-active');
        return;
      }

      const track = bar.clientHeight;
      const height = Math.max(
        MIN_THUMB,
        (window.innerHeight / doc.scrollHeight) * track
      );
      const progress = Math.min(1, Math.max(0, window.scrollY / scrollable));

      thumb.style.height = `${height}px`;
      thumb.style.transform = `translateY(${progress * (track - height)}px)`;
    };

    const show = () => {
      if (document.documentElement.scrollHeight <= window.innerHeight) return;
      bar.classList.add('is-active');
      window.clearTimeout(idleTimer);
      idleTimer = window.setTimeout(
        () => bar.classList.remove('is-active'),
        IDLE_MS
      );
    };

    const onScroll = () => {
      if (!frame) frame = requestAnimationFrame(render);
      show();
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
      if (!frame) frame = requestAnimationFrame(render);
    });

    render();
  }

  setupScrollIndicator();
  document.addEventListener('astro:page-load', setupScrollIndicator);
</script>
