---
import type { CaseLocale } from '../../lib/cases';

interface Props {
  locale: CaseLocale;
}

const { locale } = Astro.props as Props;
const title = locale === 'en' ? 'On this page' : 'Содержание';
---

<nav class="case-toc not-prose" aria-label={title} data-case-toc>
  <div class="case-toc__rail" data-toc-rail></div>

  <div class="case-toc__panel" data-toc-panel>
    <ol class="case-toc__list" data-toc-list></ol>
  </div>
</nav>

<script>
  type TocItem = {
    id: string;
    text: string;
    level: number;
    heading: HTMLElement;
  };

  let activeTocRoot: HTMLElement | null = null;
  let cleanupCaseToc: (() => void) | undefined;

  const initCaseToc = () => {
    const tocRoot = document.querySelector<HTMLElement>('[data-case-toc]');
    if (tocRoot === activeTocRoot) return;

    cleanupCaseToc?.();
    cleanupCaseToc = undefined;
    activeTocRoot = tocRoot;
    if (!tocRoot) return;

    const controller = new AbortController();
    const { signal } = controller;
    const cleanup = () => {
      controller.abort();
      if (activeTocRoot === tocRoot) activeTocRoot = null;
      if (cleanupCaseToc === cleanup) cleanupCaseToc = undefined;
    };
    cleanupCaseToc = cleanup;
    document.addEventListener('astro:before-swap', cleanup, { once: true, signal });

    tocRoot.dataset.ready = 'true';

    const rail = document.querySelector<HTMLElement>('[data-toc-rail]');
    const list = document.querySelector<HTMLOListElement>('[data-toc-list]');
    const article = document.querySelector<HTMLElement>('article.prose') ?? document.body;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const slugify = (text: string) =>
      text
        .trim()
        .toLowerCase()
        .replace(/[^\p{Letter}\p{Number}]+/gu, '-')
        .replace(/^-+|-+$/g, '');

    const ensureHeadingId = (heading: HTMLElement, usedIds: Set<string>) => {
    if (heading.id) {
      usedIds.add(heading.id);
      return heading.id;
    }

    const base = slugify(heading.textContent ?? '') || 'section';
    let id = base;
    let index = 2;

    while (usedIds.has(id) || document.getElementById(id)) {
      id = `${base}-${index}`;
      index += 1;
    }

    heading.id = id;
    usedIds.add(id);
    return id;
  };

    const getScrollTarget = (heading: HTMLElement) => {
    const topOffset = 24;
    return Math.max(0, window.scrollY + heading.getBoundingClientRect().top - topOffset);
  };

    const animateScrollTo = (targetY: number) => {
    if (reduceMotion.matches) {
      window.scrollTo(0, targetY);
      return;
    }

    const startY = window.scrollY;
    const distance = targetY - startY;
    // Duration scales with distance (Notion-like): short jumps feel instant,
    // long jumps stay readable. Clamped so it never drags.
    const duration = Math.min(700, Math.max(180, Math.abs(distance) * 0.4));
    const startTime = performance.now();
    const ease = (t: number) => 1 - Math.pow(1 - t, 3);

    const step = (now: number) => {
      if (signal.aborted) return;
      const progress = Math.min(1, (now - startTime) / duration);
      window.scrollTo(0, startY + distance * ease(progress));

      if (progress < 1) {
        window.requestAnimationFrame(step);
      }
    };

    window.requestAnimationFrame(step);
  };

    const usedIds = new Set<string>();
    const tocItems: TocItem[] = Array.from(
    article.querySelectorAll<HTMLElement>('h2, h3, h4'),
  )
    .filter((heading) => !heading.closest('.not-prose'))
    .map((heading) => ({
      id: ensureHeadingId(heading, usedIds),
      text: heading.textContent?.trim() ?? '',
      level: Number(heading.tagName.slice(1)),
      heading,
    }))
    .filter((item) => item.text.length > 0);

  // Normalize levels so the shallowest heading present maps to depth 0.
    const minLevel = tocItems.reduce(
    (min, item) => Math.min(min, item.level),
    Infinity,
  );

    if (tocItems.length < 2 || !rail || !list) {
      tocRoot.setAttribute('hidden', '');
    } else {
    tocItems.forEach((item, index) => {
      const depth = item.level - minLevel;

      const bar = document.createElement('a');
      bar.className = 'case-toc__bar';
      bar.href = `#${item.id}`;
      bar.dataset.tocIndex = String(index);
      bar.dataset.depth = String(depth);
      bar.setAttribute('aria-label', item.text);
      rail.append(bar);

      const li = document.createElement('li');
      li.className = 'case-toc__item';
      li.dataset.depth = String(depth);

      const link = document.createElement('a');
      link.className = 'case-toc__link';
      link.href = `#${item.id}`;
      link.dataset.tocIndex = String(index);
      link.textContent = item.text;

      li.append(link);
      list.append(li);
    });

    const getLinks = () =>
      Array.from(tocRoot.querySelectorAll<HTMLAnchorElement>('[data-toc-index]'));

    const setActive = (activeIndex: number) => {
      getLinks().forEach((link) => {
        const isActive = Number(link.dataset.tocIndex) === activeIndex;
        link.classList.toggle('is-active', isActive);

        if (isActive) {
          link.setAttribute('aria-current', 'location');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    };

    const getActiveIndex = () => {
      // Keep the anchor close to where clicks land (heading top + ~24px) so
      // tightly spaced headings don't hand the highlight to a neighbour.
      const anchorY = Math.min(window.innerHeight * 0.25, 120);
      let activeIndex = 0;

      tocItems.forEach((item, index) => {
        if (item.heading.getBoundingClientRect().top <= anchorY) {
          activeIndex = index;
        }
      });

      return activeIndex;
    };

    let ticking = false;
    let currentIndex = -1;
    // After a click we lock the highlight to the clicked item and ignore the
    // scroll events fired by the smooth-scroll animation. Genuine user input
    // (wheel / touch / arrow keys) releases the lock and resumes scroll-spy.
    let lockToClicked = false;

    const requestActiveUpdate = () => {
      if (lockToClicked || ticking) return;

      window.requestAnimationFrame(() => {
        if (signal.aborted) return;
        const nextIndex = getActiveIndex();

        if (nextIndex !== currentIndex) {
          currentIndex = nextIndex;
          setActive(nextIndex);
        }

        ticking = false;
      });

      ticking = true;
    };

    tocRoot.addEventListener('click', (event) => {
      const link = (event.target as HTMLElement).closest<HTMLAnchorElement>('[data-toc-index]');

      if (!link) return;

      const index = Number(link.dataset.tocIndex);
      const item = tocItems[index];

      if (!item) return;

      event.preventDefault();
      lockToClicked = true;
      currentIndex = index;
      setActive(index);
      animateScrollTo(getScrollTarget(item.heading));
      history.replaceState(null, '', `#${item.id}`);
    }, { signal });

    const releaseLock = () => {
      lockToClicked = false;
    };

    window.addEventListener('scroll', requestActiveUpdate, { passive: true, signal });
    window.addEventListener('resize', requestActiveUpdate, { passive: true, signal });
    // Only real user-driven scrolling should hand control back to scroll-spy.
    window.addEventListener('wheel', releaseLock, { passive: true, signal });
    window.addEventListener('touchmove', releaseLock, { passive: true, signal });
    window.addEventListener('keydown', releaseLock, { signal });

      requestActiveUpdate();
    }
  };

  document.addEventListener('astro:page-load', initCaseToc);
  initCaseToc();
</script>

<style>
  .case-toc {
    position: fixed;
    top: 50%;
    right: clamp(1rem, 3vw, 2rem);
    z-index: 40;
    width: 1.5rem;
    transform: translateY(-50%);
  }

  .case-toc[hidden] {
    display: none;
  }

  /* Hover bridge so the panel stays reachable. */
  .case-toc::before {
    position: absolute;
    top: -0.5rem;
    right: 100%;
    bottom: -0.5rem;
    width: 1rem;
    content: '';
  }

  .case-toc__rail {
    display: grid;
    gap: 0.75rem;
    justify-items: end;
    padding: 0.25rem 0;
  }

  .case-toc__rail :global(.case-toc__bar) {
    display: block;
    height: 0.125rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-text) 28%, transparent);
    transition:
      background-color 160ms ease,
      opacity 160ms ease;
  }

  /* Bar length encodes heading depth. */
  .case-toc__rail :global(.case-toc__bar[data-depth='0']) {
    width: 1rem;
  }
  .case-toc__rail :global(.case-toc__bar[data-depth='1']) {
    width: 0.75rem;
  }
  .case-toc__rail :global(.case-toc__bar[data-depth='2']) {
    width: 0.5rem;
  }

  .case-toc__rail :global(.case-toc__bar:hover),
  .case-toc__rail :global(.case-toc__bar:focus-visible) {
    background: color-mix(in srgb, var(--color-text) 55%, transparent);
    outline: none;
  }

  .case-toc__rail :global(.case-toc__bar.is-active) {
    background: var(--color-text);
  }

  /* Fade the rail out while the panel is open. */
  .case-toc:hover .case-toc__rail,
  .case-toc:focus-within .case-toc__rail {
    opacity: 0;
    pointer-events: none;
  }

  .case-toc__rail {
    transition: opacity 140ms ease;
  }

  .case-toc__panel {
    position: absolute;
    top: 50%;
    right: 0;
    width: min(16rem, calc(100vw - 5.5rem));
    /* Fit the whole TOC on the page; scroll only as a safety net on very long cases. */
    max-height: calc(100dvh - 3rem);
    overflow: auto;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    background: var(--color-bg);
    box-shadow: 0 12px 32px -12px color-mix(in srgb, var(--color-text) 24%, transparent);
    opacity: 0;
    transform: translate(0.5rem, -50%);
    transition:
      opacity 140ms ease,
      transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
    pointer-events: none;
  }

  .case-toc:hover .case-toc__panel,
  .case-toc:focus-within .case-toc__panel {
    opacity: 1;
    transform: translate(0, -50%);
    pointer-events: auto;
  }

  .case-toc__list {
    display: grid;
    gap: 0.125rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .case-toc__list :global(.case-toc__item) {
    min-width: 0;
  }

  .case-toc__list :global(.case-toc__item[data-depth='1']) {
    padding-left: 0.75rem;
  }
  .case-toc__list :global(.case-toc__item[data-depth='2']) {
    padding-left: 1.5rem;
  }

  .case-toc__list :global(.case-toc__link) {
    display: block;
    padding: 0.375rem 0.625rem;
    border-radius: 0.375rem;
    color: var(--color-text-muted);
    font-size: 0.8125rem;
    line-height: 1.4;
    text-decoration: none;
    text-wrap: pretty;
    transition:
      color 140ms ease,
      background-color 140ms ease;
  }

  .case-toc__list :global(.case-toc__link:hover),
  .case-toc__list :global(.case-toc__link:focus-visible) {
    color: var(--color-text);
    background: var(--color-bg-subtle);
  }

  .case-toc__list :global(.case-toc__link.is-active) {
    color: var(--color-text);
    font-weight: 600;
  }

  .case-toc__list :global(.case-toc__link:focus-visible) {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  @media (max-width: 860px) {
    .case-toc {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-toc__panel {
      transition: opacity 140ms ease;
    }
  }
</style>
