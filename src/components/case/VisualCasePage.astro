---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { ClientRouter } from 'astro:transitions';
import { stripLocale } from '../../i18n/paths';
import { defaultLocale, type Locale } from '../../lib/i18n';
import SeoMeta from '../common/SeoMeta.astro';
import YandexMetrika from '../common/YandexMetrika.astro';
import CaseNav from './CaseNav.astro';
import CaseSliceImage from './CaseSliceImage.astro';
import CaseScrollIndicator from './CaseScrollIndicator.astro';
import CaseSliceVideo from './CaseSliceVideo.astro';
import type { VisualCaseBoard } from '../../content/data/visual-cases';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  ariaLabel: string;
  sliceAltPrefix: string;
  boards: VisualCaseBoard[];
  cover: ImageMetadata;
  background: string;
  videoSpinner: 'light' | 'dark';
}

const {
  locale,
  title,
  description,
  ariaLabel,
  sliceAltPrefix,
  boards,
  cover,
  background,
  videoSpinner,
} = Astro.props as Props;

const basePath = stripLocale(Astro.url.pathname);
const enUrl = getRelativeLocaleUrl(defaultLocale, basePath);
const ruUrl = getRelativeLocaleUrl('ru', basePath);
const toAbs = (url: string) => new URL(url, Astro.site ?? Astro.url.origin);
const canvasLabel =
  locale === 'ru'
    ? 'Прокручиваемые визуальные материалы кейса'
    : 'Scrollable visual case boards';
const responsiveSizes = '100vw';
---

<!doctype html>
<html lang={locale} style={`--visual-case-bg:${background}`}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style is:inline>
      html,
      body {
        margin: 0;
        background: var(--visual-case-bg, #000);
      }
      html {
        color-scheme: dark;
      }
    </style>
    <SeoMeta
      title={title}
      description={description}
      image={cover}
      imageAlt={ariaLabel}
      type="article"
    />
    <link rel="alternate" hreflang="en" href={toAbs(enUrl)} />
    <link rel="alternate" hreflang="ru" href={toAbs(ruUrl)} />
    <link rel="alternate" hreflang="x-default" href={toAbs(enUrl)} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ClientRouter fallback="swap" />
  </head>
  <body>
    <YandexMetrika />
    <CaseNav variant="floating" locale={locale} />
    <main
      class="visual-case__scroller"
      aria-label={ariaLabel}
      tabindex="0"
    >
      <div class="visual-case__canvas" role="region" aria-label={canvasLabel}>
        {
          boards.map((board, index) => {
            const label = `${sliceAltPrefix} ${String(index + 1).padStart(2, '0')}`;
            return board.kind === 'video' ? (
              <CaseSliceVideo
                src={board.src}
                aspectRatio={board.aspectRatio}
                label={label}
                spinner={videoSpinner}
              />
            ) : (
              <CaseSliceImage
                src={board.src}
                alt={label}
                eager={index === 0}
                sizes={responsiveSizes}
              />
            );
          })
        }
      </div>
    </main>
    <CaseScrollIndicator />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    min-width: 320px;
    background: var(--visual-case-bg, #000);
  }

  /* Скроллбар убран из РАСКЛАДКИ намеренно. Борды идут во всю ширину, поэтому
     место отрисовки = ширина вьюпорта минус скроллбар. Полоса в 11px делала из
     1920 → 1909, а дробное уменьшение почти на единицу — самое разрушительное:
     каждый пиксель становится смесью двух соседних, и текст теряет ~25%
     резкости (замерено). Без полосы ширина совпадает со ступенью 1920 ровно, и
     браузер не пересчитывает ничего. Прокрутка колесом, клавишами и тачем
     работает как обычно. */
  html {
    color-scheme: dark;
    scrollbar-width: none;
  }

  html::-webkit-scrollbar {
    width: 0;
    height: 0;
  }

  body {
    overflow-x: hidden;
  }

  .visual-case__scroller,
  .visual-case__canvas {
    width: 100%;
    background: var(--visual-case-bg, #000);
  }

  .visual-case__scroller:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.8);
    outline-offset: -2px;
  }

  img {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
    padding: 0;
    border: 0;
    image-rendering: auto;
  }

</style>
