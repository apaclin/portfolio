---
// «Разбор интерфейса» (guided walkthrough) — порт прототипа v11 на стек проекта.
// Explore: hover по зоне → мгновенная рамка + peek-карточка (последовательная
// смена без наложения). Guided (клик по зоне / кнопке): модальный разбор с
// blur-затемнением, резкой clip-path копией активной зоны, счётчиком шага и
// фиксированной панелью Назад/Далее/закрыть.
//
// Зоны приходят пропом (typed Zone[]) — не хардкодятся в разметке. Координаты —
// проценты холста 1440×900. Резкая копия — вторая <Picture> с тем же src,
// обрезанная clip-path. Карточка и панель фиксированы по прототипу v11,
// primary-кнопка — через токены --color-primary-*.
import { Picture } from 'astro:assets';
import Icon from '../icons/Icon.astro';
import type { Zone } from '../../content/data/t-taxi/zones';

interface Props {
  src: ImageMetadata;
  alt: string;
  title: string;
  description: string;
  zones: Zone[];
  locale?: 'en' | 'ru';
  hint?: string;
  cta?: string;
  replayCta?: string;
  maxWidth?: string;
}

const locale = (Astro.props.locale ?? (Astro.currentLocale === 'ru' ? 'ru' : 'en')) as 'en' | 'ru';
const ui = {
  ru: {
    hint: 'Наведите на области экрана или запустите пошаговый разбор.',
    cta: 'Разобрать экран',
    replayCta: 'Посмотреть разбор снова',
    first: 'В начало',
    prev: 'Назад',
    next: 'Далее',
    done: 'Готово',
    close: 'Закрыть разбор',
    captionIdle: 'Наведите — обводка сразу, превью следом. Клик — пошаговый разбор.',
    captionKeys: 'двигают рамку между шагами · клик по экрану /',
    captionExit: '— выход',
    captionStarted:
      'Разбор запущен. Стрелки двигают рамку между шагами. Клик по экрану или Esc — выход.',
    captionCompleted: 'Разбор пройден. Наведите на зоны, чтобы вернуться к любой.',
  },
  en: {
    hint: 'Hover over screen areas or start the step-by-step walkthrough.',
    cta: 'Break down screen',
    replayCta: 'Watch walkthrough again',
    first: 'Back to start',
    prev: 'Back',
    next: 'Next',
    done: 'Done',
    close: 'Close walkthrough',
    captionIdle: 'Hover — outline first, preview follows. Click — step-by-step walkthrough.',
    captionKeys: 'move the frame between steps · click the screen /',
    captionExit: '— exit',
    captionStarted:
      'Walkthrough started. Arrow keys move the frame between steps. Click the screen or press Esc to exit.',
    captionCompleted: 'Walkthrough complete. Hover over zones to jump back to any step.',
  },
}[locale];

const {
  src,
  alt,
  title,
  description,
  zones,
  hint = ui.hint,
  cta = ui.cta,
  replayCta = ui.replayCta,
  maxWidth = '1440px',
} = Astro.props as Props;

const widths = [720, 960, 1200, 1440, 1920].filter((w) => w < src.width).concat(src.width);
const sizes = '(min-width: 92rem) 1440px, calc(100vw - 2rem)';
---

<section
  class="walkthrough not-prose full-bleed"
  data-walkthrough
  data-cta={cta}
  data-replay-cta={replayCta}
  data-next-label={ui.next}
  data-done-label={ui.done}
  data-caption-idle={ui.captionIdle}
  data-caption-started={ui.captionStarted}
  data-caption-completed={ui.captionCompleted}
>
  <div class="walkthrough__intro">
    <div>
      <h2>{title}</h2>
      <p>{description}</p>
      <p class="walkthrough__hint">
        <Icon name="zap" size={16} class="walkthrough__hint-ico" />
        {hint}
      </p>
    </div>
    <button class="walkthrough__start" type="button" data-start>{cta}</button>
  </div>

  <div class="walkthrough__wide">
    <div class="walkthrough__stage-wrap" style={`max-width: ${maxWidth};`}>
      <div class="walkthrough__stage explore" data-stage>
        <div class="walkthrough__layer walkthrough__layer--base">
          <Picture
            src={src}
            alt={alt}
            formats={['avif', 'webp']}
            widths={widths}
            sizes={sizes}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="walkthrough__dim"></div>
        <div class="walkthrough__layer walkthrough__layer--sharp" data-sharp>
          <Picture
            src={src}
            alt=""
            formats={['avif', 'webp']}
            widths={widths}
            sizes={sizes}
            loading="lazy"
            decoding="async"
            aria-hidden="true"
          />
        </div>
        <div class="walkthrough__frame" data-frame></div>
        <div class="walkthrough__regions">
          {
            zones.map((z, i) => (
              <button
                class="walkthrough__region"
                type="button"
                data-region
                data-index={i}
                data-l={z.l}
                data-t={z.t}
                data-w={z.w}
                data-h={z.h}
                data-title={z.title}
                data-body={z.body}
                style={`left:${z.l}%;top:${z.t}%;width:${z.w}%;height:${z.h}%;`}
                aria-label={`${i + 1}. ${z.title}`}
              />
            ))
          }
        </div>
        <div class="walkthrough__card" data-card role="dialog" aria-live="polite">
          <div class="walkthrough__step" data-card-step></div>
          <h3 data-card-title></h3>
          <p data-card-body></p>
        </div>
        <div class="walkthrough__controls" data-controls>
          <button
            class="walkthrough__nav walkthrough__nav--icon"
            type="button"
            data-first
            aria-label={ui.first}
            title={ui.first}
          >
            <Icon name="chevron-first" size={14} />
          </button>
          <button class="walkthrough__nav" type="button" data-prev aria-label={ui.prev}>
            <Icon name="chevron-left" size={14} />
            {ui.prev}
          </button>
          <button
            class="walkthrough__nav walkthrough__nav--primary"
            type="button"
            data-next
            aria-label={ui.next}
          >
            <span data-next-text>{ui.next}</span>
            <Icon name="chevron-right" size={14} class="walkthrough__next-go" />
            <Icon name="check" size={14} class="walkthrough__next-done" />
          </button>
          <span class="walkthrough__sep"></span>
          <button class="walkthrough__close" type="button" data-close aria-label={ui.close}>
            <Icon name="x" size={16} />
          </button>
        </div>
      </div>
    </div>
  </div>

  <p class="walkthrough__caption">
    <span data-cap-left>{ui.captionIdle}</span>
    <span class="walkthrough__caption-keys">
      <kbd>←</kbd> <kbd>→</kbd> {ui.captionKeys} <kbd>Esc</kbd> {ui.captionExit}
    </span>
  </p>
</section>

<script>
  const initWalkthrough = (root: HTMLElement) => {
    if (root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const stage = root.querySelector<HTMLElement>('[data-stage]');
    const sharp = root.querySelector<HTMLElement>('[data-sharp]');
    const frame = root.querySelector<HTMLElement>('[data-frame]');
    const card = root.querySelector<HTMLElement>('[data-card]');
    const cardStep = root.querySelector<HTMLElement>('[data-card-step]');
    const cardTitle = root.querySelector<HTMLElement>('[data-card-title]');
    const cardBody = root.querySelector<HTMLElement>('[data-card-body]');
    const controls = root.querySelector<HTMLElement>('[data-controls]');
    const firstBtn = root.querySelector<HTMLButtonElement>('[data-first]');
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-next]');
    const nextText = root.querySelector<HTMLElement>('[data-next-text]');
    const closeBtn = root.querySelector<HTMLButtonElement>('[data-close]');
    const startBtn = root.querySelector<HTMLButtonElement>('[data-start]');
    const capLeft = root.querySelector<HTMLElement>('[data-cap-left]');
    const regionEls = [...root.querySelectorAll<HTMLButtonElement>('[data-region]')];

    if (
      !stage ||
      !sharp ||
      !frame ||
      !card ||
      !cardStep ||
      !cardTitle ||
      !cardBody ||
      !controls ||
      !firstBtn ||
      !prevBtn ||
      !nextBtn ||
      !nextText ||
      !closeBtn ||
      !startBtn ||
      !capLeft ||
      regionEls.length === 0
    ) {
      return;
    }

    interface Zone {
      l: number;
      t: number;
      w: number;
      h: number;
      title: string;
      body: string;
    }

    const zones: Zone[] = regionEls.map((el) => ({
      l: Number(el.dataset.l),
      t: Number(el.dataset.t),
      w: Number(el.dataset.w),
      h: Number(el.dataset.h),
      title: el.dataset.title || '',
      body: el.dataset.body || '',
    }));

    const N = zones.length;
    const CARD_EXIT = 250;
    const cta = root.dataset.cta || 'Разобрать экран';
    const replayCta = root.dataset.replayCta || 'Посмотреть разбор снова';
    const nextLabel = root.dataset.nextLabel || 'Далее';
    const doneLabel = root.dataset.doneLabel || 'Готово';
    const captionIdle = root.dataset.captionIdle || 'Наведите — обводка сразу, превью следом. Клик — пошаговый разбор.';
    const captionStarted =
      root.dataset.captionStarted ||
      'Разбор запущен. Стрелки двигают рамку между шагами. Клик по экрану или Esc — выход.';
    const captionCompleted =
      root.dataset.captionCompleted || 'Разбор пройден. Наведите на зоны, чтобы вернуться к любой.';

    let idx = -1;
    let guided = false;
    let completed = false;
    let hoverIdx = -1;
    let cardShownIdx = -1;
    let cardBusy = false;

    const reflow = (el: HTMLElement) => void el.offsetWidth;

    const setFramePos = (z: Zone) => {
      frame.style.left = z.l + '%';
      frame.style.top = z.t + '%';
      frame.style.width = z.w + '%';
      frame.style.height = z.h + '%';
    };

    const clipFor = (z: Zone) =>
      `inset(${z.t}% ${(100 - z.l - z.w).toFixed(2)}% ${(100 - z.t - z.h).toFixed(2)}% ${z.l}% round 8px)`;

    const fillCard = (i: number) => {
      const z = zones[i];
      cardStep.textContent = i + 1 + ' / ' + N;
      cardTitle.textContent = z.title;
      cardBody.textContent = z.body;
    };

    const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

    const placeCard = (z: Zone, fg: boolean) => {
      const W = stage.clientWidth;
      const H = stage.clientHeight;
      const fl = (z.l / 100) * W;
      const ft = (z.t / 100) * H;
      const fw = (z.w / 100) * W;
      const cw = card.offsetWidth || 336;
      const ch = card.offsetHeight || 120;
      const gap = 14;
      const cx = fl + fw / 2;
      // Сторона по свободному месту, карточка вплотную к зоне (v11).
      let left = cx < W / 2 ? fl + fw + gap : fl - gap - cw;
      left = clamp(left, 10, Math.max(10, W - cw - 10));
      // Выравнивание по верху зоны (v11), а не центрирование.
      let top = ft;
      const maxTop = H - ch - (fg ? 96 : 12);
      top = clamp(top, 10, Math.max(10, maxTop));
      card.style.left = Math.round(left) + 'px';
      card.style.top = Math.round(top) + 'px';
    };

    const setNextLabel = (i: number) => {
      const last = i === N - 1;
      nextText.textContent = last ? doneLabel : nextLabel;
      nextBtn.classList.toggle('is-last', last);
    };

    // ── Explore-режим: последовательная смена peek-карточек (без наложения) ──
    const showCardVisual = (i: number) => {
      fillCard(i);
      // peek без счётчика. step-static замораживает переход .step, поэтому после
      // выхода из guided счётчик не «доигрывает» появление/сворачивание — он
      // просто отсутствует, а карточка приезжает обычным fade + translateY.
      card.classList.remove('moving');
      card.classList.add('step-static');
      card.classList.remove('stepped');
      placeCard(zones[i], false);
      card.classList.add('show');
    };
    const hideCardVisual = () => card.classList.remove('show');

    const syncCard = () => {
      if (guided || cardBusy) return;
      if (hoverIdx === cardShownIdx) return;
      if (cardShownIdx !== -1) {
        hideCardVisual();
        cardShownIdx = -1;
        cardBusy = true;
        setTimeout(() => {
          cardBusy = false;
          syncCard();
        }, CARD_EXIT);
      } else if (hoverIdx !== -1) {
        showCardVisual(hoverIdx);
        cardShownIdx = hoverIdx;
      }
    };

    // Пока идёт наш программный скролл (вход / навигация), автовыход по уходу
    // сцены из вида подавляется — иначе промежуточные кадры плавного скролла
    // закрыли бы разбор ещё до того, как сцена доедет до центра.
    let suppressExitUntil = 0;

    // Если сцена не помещается в вьюпорт целиком — плавно скроллим так, чтобы
    // её центр совпал с центром вьюпорта (вход через кнопку «Разобрать экран»).
    const scrollStageIntoView = () => {
      const rect = stage.getBoundingClientRect();
      const vh = window.innerHeight;
      if (rect.top >= 0 && rect.bottom <= vh) return;
      const targetY = window.scrollY + rect.top + rect.height / 2 - vh / 2;
      suppressExitUntil = performance.now() + 800;
      window.scrollTo({ top: Math.max(0, targetY), behavior: 'smooth' });
    };

    // ── Вход в guided ──
    const enterGuided = (i: number, fromPeek: boolean) => {
      guided = true;
      stage.classList.remove('explore');
      stage.classList.add('guided');
      root.classList.add('is-guided');
      // Только один активный разбор: другие закрываются.
      document.dispatchEvent(new CustomEvent('t-walkthrough-open', { detail: root }));

      const cameFromVisiblePeek = fromPeek && cardShownIdx === i;
      hoverIdx = -1;
      cardShownIdx = -1;
      cardBusy = false;

      frame.classList.remove('moving');
      sharp.classList.remove('moving');
      reflow(frame);
      setFramePos(zones[i]);
      sharp.style.clipPath = clipFor(zones[i]);
      fillCard(i);
      card.classList.remove('moving');

      if (cameFromVisiblePeek) {
        // Клик по зоне с уже видимым peek: карточка «дорастает» счётчиком
        // (анимация max-height у .step), рамка фейдится с утолщением. Не
        // переезжает — КРОМЕ случая, когда выросшая карточка налезла бы на
        // панель управления: тогда плавно поднимаем её ровно настолько, чтобы
        // не перекрывать (вариант C).
        card.classList.remove('step-static');
        setNextLabel(i);
        prevBtn.disabled = i === 0;
        firstBtn.disabled = i === 0;
        frame.classList.add('on');
        sharp.style.opacity = '1';
        card.classList.add('show', 'stepped');
        // .step вырастет на max-height 22px + margin-bottom 12px = 34px.
        const stepDelta = 34;
        const chFinal = card.offsetHeight + stepDelta;
        const curTop = parseFloat(card.style.top) || 0;
        const maxTop = stage.clientHeight - chFinal - 96;
        if (curTop > maxTop) {
          card.classList.add('moving');
          card.style.top = Math.round(Math.max(10, maxTop)) + 'px';
          window.setTimeout(() => card.classList.remove('moving'), 460);
        }
      } else {
        // Вход через кнопку (без предварительного hover): карточка подъезжает
        // снизу вверх с fade-in, как peek, но счётчик показан сразу вместе с
        // карточкой — без отдельной «растущей» анимации (.step-static).
        card.classList.remove('show');
        card.classList.add('stepped', 'step-static');
        placeCard(zones[i], true);
        setNextLabel(i);
        prevBtn.disabled = i === 0;
        firstBtn.disabled = i === 0;
        reflow(card);
        frame.classList.add('on');
        sharp.style.opacity = '1';
        card.classList.add('show');
      }

      idx = i;
      scrollStageIntoView();
      capLeft.textContent = captionStarted;
    };

    // ── Навигация Назад/Далее: единственный «перелёт» рамки/резкости/карточки ──
    const step = (i: number) => {
      [frame, card, sharp].forEach((el) => el.classList.add('moving'));
      reflow(frame);
      setFramePos(zones[i]);
      sharp.style.clipPath = clipFor(zones[i]);
      fillCard(i);
      placeCard(zones[i], true);
      setNextLabel(i);
      prevBtn.disabled = i === 0;
      firstBtn.disabled = i === 0;
      frame.classList.add('on');
      sharp.style.opacity = '1';
      card.classList.add('show', 'stepped');
      idx = i;
      scrollStageIntoView(); // если ушли скроллом — вернуть сцену в вид
    };

    const next = () => {
      if (idx < N - 1) step(idx + 1);
      else {
        completed = true;
        closeGuided();
      }
    };
    const prev = () => {
      if (idx > 0) step(idx - 1);
    };

    const closeGuided = () => {
      guided = false;
      stage.classList.remove('guided');
      stage.classList.add('explore');
      root.classList.remove('is-guided');
      frame.classList.remove('on', 'moving');
      sharp.classList.remove('moving');
      sharp.style.opacity = '0';
      // Выход: только fade-out + отъезд карточки вниз, как при уходе курсора из
      // зоны. Счётчик шага НЕ сворачивается своей анимацией — .step-static
      // замораживает переход .step, 'stepped' остаётся, гаснет вместе с карточкой.
      card.classList.add('step-static');
      card.classList.remove('show', 'moving');
      idx = -1;
      hoverIdx = -1;
      cardShownIdx = -1;
      cardBusy = false;
      startBtn.textContent = completed ? replayCta : cta;
      capLeft.textContent = completed ? captionCompleted : captionIdle;
    };

    regionEls.forEach((el, i) => {
      el.addEventListener('mouseenter', () => {
        if (guided) return;
        hoverIdx = i;
        syncCard();
      });
      el.addEventListener('mouseleave', () => {
        if (guided) return;
        if (hoverIdx === i) {
          hoverIdx = -1;
          syncCard();
        }
      });
      el.addEventListener('click', (e) => {
        e.stopPropagation();
        if (guided) {
          // Клик по активной зоне — остаёмся в разборе. Клик по любой другой
          // зоне визуально приходится на затемнение (остальные зоны скрыты),
          // поэтому ощущается как клик по фону → выходим из разбора.
          if (i !== idx) closeGuided();
          return;
        }
        enterGuided(i, true);
      });
    });

    document.addEventListener('t-walkthrough-open', (e) => {
      if ((e as CustomEvent).detail !== root && guided) closeGuided();
    });

    // Выход — только клик ВНЕ скриншота (не по сцене, панели и кнопке запуска).
    document.addEventListener('click', (e) => {
      if (!guided) return;
      const t = e.target as Node;
      if (stage.contains(t) || controls.contains(t) || startBtn.contains(t)) return;
      closeGuided();
    });

    startBtn.addEventListener('click', () => enterGuided(0, false));
    firstBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      if (idx > 0) step(0);
    });
    nextBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      next();
    });
    prevBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      prev();
    });
    closeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      closeGuided();
    });
    card.addEventListener('click', (e) => e.stopPropagation());
    controls.addEventListener('click', (e) => e.stopPropagation());
    // Клик по сцене мимо зоны — выход (по зонам стоит stopPropagation).
    stage.addEventListener('click', () => {
      if (guided) closeGuided();
    });

    window.addEventListener('keydown', (e) => {
      if (!guided) return;
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        next();
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        prev();
      } else if (e.key === 'Home') {
        e.preventDefault();
        if (idx > 0) step(0);
      } else if (e.key === 'Escape') {
        e.preventDefault();
        closeGuided();
      }
    });

    let rt: number;
    window.addEventListener('resize', () => {
      clearTimeout(rt);
      rt = window.setTimeout(() => {
        if (guided && idx >= 0) placeCard(zones[idx], true);
        else if (cardShownIdx >= 0) placeCard(zones[cardShownIdx], false);
      }, 80);
    });

    // ── Автовыход при уходе сцены из вида ──
    // Сцена скрылась (проскроллили по вертикали или увели вбок во внутреннем
    // горизонтальном скролле) → выходим из разбора. Порог — ~30% видимой части
    // сцены по каждой оси; min(размер сцены, размер вьюпорта) корректно
    // обрабатывает сцену выше/шире вьюпорта.
    const wide = root.querySelector<HTMLElement>('.walkthrough__wide');
    const isStageMostlyVisible = () => {
      const r = stage.getBoundingClientRect();
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const visibleX = Math.min(r.right, vw) - Math.max(r.left, 0);
      const visibleY = Math.min(r.bottom, vh) - Math.max(r.top, 0);
      const minX = Math.min(r.width, vw) * 0.3;
      const minY = Math.min(r.height, vh) * 0.3;
      return visibleX > minX && visibleY > minY;
    };

    let exitRaf = 0;
    const checkAutoExit = () => {
      if (exitRaf) return;
      exitRaf = window.requestAnimationFrame(() => {
        exitRaf = 0;
        if (!guided) return;
        if (performance.now() < suppressExitUntil) return;
        if (!isStageMostlyVisible()) closeGuided();
      });
    };

    window.addEventListener('scroll', checkAutoExit, { passive: true });
    wide?.addEventListener('scroll', checkAutoExit, { passive: true });
  };

  const initWalkthroughs = () => {
    document.querySelectorAll<HTMLElement>('[data-walkthrough]').forEach(initWalkthrough);
  };

  document.addEventListener('astro:page-load', initWalkthroughs);
