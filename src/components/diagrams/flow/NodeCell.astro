---
import Icon from '../../icons/Icon.astro';
import type { FlowNode, NodeVariant } from './types';

interface Props {
  node: FlowNode;
  locale: 'en' | 'ru';
}
const { node, locale } = Astro.props;
const variant: NodeVariant = node.variant ?? 'default';
---

<figure class="flex w-28 shrink-0 flex-col items-center gap-2">
  <span
    class="grid h-12 w-12 place-items-center"
    style={`background:var(--color-node-${variant}-bg);color:var(--color-node-${variant}-fg);border-radius:var(--flow-radius)`}
  >
    <Icon name={node.icon} size={22} />
  </span>
  <figcaption class="text-center text-sm leading-tight text-black/80">
    {node.label[locale]}
  </figcaption>
</figure>
