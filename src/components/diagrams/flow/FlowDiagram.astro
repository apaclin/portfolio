---
import type { FlowData, FlowNode, Localized } from './types';
import NodeCell from './NodeCell.astro';
import Fork from './Fork.astro';

interface Props {
  data: FlowData;
  // Оверрайды в стиле Figma-instance: дефолты зашиты, переопределяешь по нужде.
  accent?: string;
  strokeWidth?: number;
  radius?: number;
}
const { data, accent, strokeWidth = 2, radius = 12 } = Astro.props;

// Локаль выбирается на сборке (фоллбэк 'en'). Никакого client JS.
const locale: 'en' | 'ru' = Astro.currentLocale === 'ru' ? 'ru' : 'en';

// --- Чистый шов под будущий вертикальный рендер ---
// Реализован только горизонтальный поток. direction:'vertical' допустим типом,
// но рендерится отдельной веткой в следующем шаге Фазы 3. Не реализуем наполовину.
const isVertical = data.direction === 'vertical';

// Сборка последовательности шагов из nodes+edges: линейный обход с поддержкой
// одной концевой развилки (fork). Слияние веток — будущее расширение.
type Step =
  | { kind: 'node'; node: FlowNode }
  | { kind: 'arrow'; caption?: Localized }
  | { kind: 'fork'; targets: FlowNode[]; caption?: Localized };

const nodeById = new Map(data.nodes.map((node) => [node.id, node]));

function buildSteps(): Step[] {
  const steps: Step[] = [];
  // Стартовый узел — тот, что не является целью ни одной связи.
  const asTarget = new Set<string>();
  for (const edge of data.edges) {
    (Array.isArray(edge.to) ? edge.to : [edge.to]).forEach((id) => asTarget.add(id));
  }
  let current: FlowNode | undefined =
    data.nodes.find((node) => !asTarget.has(node.id)) ?? data.nodes[0];

  const visited = new Set<string>();
  while (current && !visited.has(current.id)) {
    visited.add(current.id);
    steps.push({ kind: 'node', node: current });

    const edge = data.edges.find((e) => e.from === current!.id);
    if (!edge) break;

    if (Array.isArray(edge.to)) {
      const targets = edge.to
        .map((id) => nodeById.get(id))
        .filter((node): node is FlowNode => Boolean(node));
      steps.push({ kind: 'fork', targets, caption: edge.caption });
      break; // ветки развилки терминальны в этом минимальном рендере
    }

    steps.push({ kind: 'arrow', caption: edge.caption });
    current = nodeById.get(edge.to);
  }
  return steps;
}

const steps = isVertical ? [] : buildSteps();

// Оверрайды → CSS-переменные на корне (дефолты зашиты здесь).
const rootStyle = [
  `--flow-accent:${accent ?? 'var(--color-accent)'}`,
  `--flow-stroke:${strokeWidth}`,
  `--flow-radius:${radius}px`,
].join(';');

const swipeHint = locale === 'ru' ? 'Свайп' : 'Swipe';
---

{
  isVertical ? (
    /* Вертикальный поток — будущее расширение (следующий шаг Фазы 3).
       Шов оставлен намеренно: тип допускает, рендер появится позже. */
    null
  ) : (
    <figure class="full-bleed not-prose mx-auto my-8 max-w-[60rem] px-5 sm:px-6" style={rootStyle}>
      {data.title && (
        <figcaption class="mb-4 flex items-center gap-2">
          <span class="h-4 w-1 rounded-full" style="background:var(--flow-accent)" />
          <span class="text-base font-semibold text-[var(--color-text)]">{data.title[locale]}</span>
        </figcaption>
      )}

      <div class="relative">
        <div class="flex items-center gap-2 overflow-x-auto pb-2">
          {steps.map((step) =>
            step.kind === 'node' ? (
              <NodeCell node={step.node} locale={locale} />
            ) : step.kind === 'fork' ? (
              <Fork targets={step.targets} caption={step.caption} locale={locale} />
            ) : (
              <div class="flex shrink-0 flex-col items-center">
                {step.caption && (
                  <span class="mb-1 max-w-[8rem] text-center text-xs text-[var(--color-text-muted)]">
                    {step.caption[locale]}
                  </span>
                )}
                <svg
                  width="40"
                  height="24"
                  viewBox="0 0 40 24"
                  fill="none"
                  aria-hidden="true"
                  stroke="var(--color-diagram-line)"
                  stroke-width="var(--flow-stroke)"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <line x1="2" y1="12" x2="32" y2="12" />
                  <path d="M30 6 38 12 30 18" />
                </svg>
              </div>
            )
          )}
        </div>

        {/* Мобильный намёк на продолжение: градиент справа + подсказка свайпа.
            Только на узкой ширине (на md+ контент помещается). */}
        <div
          class="pointer-events-none absolute inset-y-0 right-0 w-12 md:hidden"
          style="background:linear-gradient(to right, transparent, white)"
          aria-hidden="true"
        >
        </div>
        <span
          class="pointer-events-none absolute bottom-0 right-1 text-xs text-[var(--color-text-faint)] md:hidden"
        >
          {swipeHint} →
        </span>
      </div>
    </figure>
  )
}
