---
// Аннотированный скриншот. Точки скрыты, проявляются при наведении на картинку,
// при hover/focus морфятся в annotation pill (title + опц. description) и
// сворачиваются обратно. Без кликов, без Popover API, без модальных слоёв.
// Ядро — чистый CSS; крошечный скрипт только для надёжного закрытия по тапу-вне
// на touch. Координаты — проценты.
interface Hotspot {
  x: number; // % по горизонтали
  y: number; // % по вертикали
  title: string;
  description?: string;
}
interface Props {
  src: string;
  alt: string;
  hotspots: Hotspot[];
  /** Интринсик-размеры картинки — резервируют место против CLS. */
  width?: number;
  height?: number;
}
const { src, alt, hotspots, width, height } = Astro.props as Props;
---

<figure class="full-bleed not-prose mx-auto my-8 max-w-[60rem] px-5 sm:px-6">
  <div class="hotspots-stage">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
      class="hotspots-img"
    />
    {
      hotspots.map((h) => {
        // Сторона роста pill считается на сборке: всегда внутрь картинки,
        // поэтому позиционирующий JS/кламп не нужен.
        const side = h.x > 50 ? 'left' : 'right';
        return (
          <button
            type="button"
            class="hotspot"
            data-side={side}
            style={`left:${h.x}%;top:${h.y}%`}
          >
            <span class="hotspot__label">
              <span class="hotspot__title">{h.title}</span>
              {h.description && <span class="hotspot__desc">{h.description}</span>}
            </span>
            <span class="hotspot__dot" aria-hidden="true" />
          </button>
        );
      })
    }
  </div>
</figure>

<style>
  .hotspots-stage {
    position: relative;
    line-height: 0; /* убрать щель под inline-img */
  }
  .hotspots-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
  }

  /* Точка-кнопка: прозрачная hit-зона ~28px (комфортный тач-таргет),
     центр привязан к координате. transform создаёт containing block
     для абсолютного лейбла. */
  .hotspot {
    position: absolute;
    width: 1.75rem;
    height: 1.75rem;
    transform: translate(-50%, -50%);
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    opacity: 1; /* базово видимы (touch / без hover / fail-safe) */
    transition: opacity 0.25s ease;
    z-index: 1;
  }
  /* На pointer-устройствах точки скрыты и проявляются при наведении на
     картинку или при заходе фокуса с клавиатуры. */
  @media (hover: hover) {
    .hotspot {
      opacity: 0;
    }
    .hotspots-stage:hover .hotspot,
    .hotspots-stage:focus-within .hotspot {
      opacity: 1;
    }
  }
  .hotspot:hover,
  .hotspot:focus {
    z-index: 3; /* активная поверх соседей */
  }
  .hotspot:focus {
    outline: none;
  }
  .hotspot:focus-visible .hotspot__dot {
    outline: 2px solid var(--color-text);
    outline-offset: 3px;
  }

  /* Видимая точка */
  .hotspot__dot {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0.75rem;
    height: 0.75rem;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    background-color: var(--color-accent);
    border: 2px solid var(--color-bg);
    box-shadow: 0 1px 3px color-mix(in oklab, var(--color-text) 35%, transparent);
    transition: transform 0.18s ease;
    z-index: 1; /* поверх лейбла-pill */
  }
  .hotspot:hover .hotspot__dot,
  .hotspot:focus .hotspot__dot {
    transform: translate(-50%, -50%) scale(1.18);
  }

  /* Annotation pill: вырастает из точки в одну сторону (внутрь картинки) */
  .hotspot__label {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    width: max-content; /* тянемся до естественной ширины, но не шире max-width */
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: 0.75rem;
    box-shadow: 0 6px 20px color-mix(in oklab, var(--color-text) 16%, transparent);
    padding-block: 0.4rem;
    transition:
      max-width 0.28s ease,
      opacity 0.2s ease;
  }
  /* Левая половина картинки → растём вправо (точка слева внутри pill). */
  .hotspot[data-side="right"] .hotspot__label {
    left: 0;
    padding-left: 1.6rem;
    padding-right: 0.8rem;
    text-align: left;
  }
  /* Правая половина → растём влево (точка справа внутри pill). */
  .hotspot[data-side="left"] .hotspot__label {
    right: 0;
    padding-right: 1.6rem;
    padding-left: 0.8rem;
    text-align: right;
  }
  .hotspot:hover .hotspot__label,
  .hotspot:focus .hotspot__label {
    max-width: 16rem;
    opacity: 1;
    pointer-events: auto;
  }
  .hotspot__title {
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-text);
    white-space: nowrap;
  }
  .hotspot__desc {
    font-size: 0.75rem;
    line-height: 1.35;
    color: var(--color-text-muted);
    white-space: normal;
  }

  /* Уважаем настройку «меньше движения». */
  @media (prefers-reduced-motion: reduce) {
    .hotspot,
    .hotspot__dot,
    .hotspot__label {
      transition: none;
    }
  }
</style>

<script>
  // Единственный JS: на touch tap по пустому месту снимает фокус с раскрытой
  // точки (на iOS Safari :focus иначе «залипает»). Десктоп/клавиатуре не мешает.
  document.addEventListener(
    'touchstart',
    (event) => {
      const target = event.target as Element | null;
      const active = document.activeElement as HTMLElement | null;
      if (
        active &&
        active.classList.contains('hotspot') &&
        !(target && target.closest('.hotspot'))
      ) {
        active.blur();
      }
    },
    { passive: true }
  );
</script>
