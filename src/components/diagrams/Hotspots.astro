---
// Аннотированный скриншот. ОДИН элемент морфится из точки (24×24 indigo-круг)
// в indigo-pill: тот же элемент растёт по ширине/высоте под свой текст, текст
// внутри проявляется через opacity (fade, без сдвига). Никаких отдельных
// плашек/popover/слоёв рядом. Симметричный рост от центра точки. 300ms ease-in-out.
// Координаты — проценты. Точные размеры pill меряются крошечным скриптом ниже
// (для гладкого width/height-перехода и чтобы текст не рефлоулил во время морфа).
interface Hotspot {
  x: number; // %
  y: number; // %
  title: string;
  description?: string;
}
interface Props {
  src: string;
  alt: string;
  hotspots: Hotspot[];
  /** Интринсик-размеры картинки — резервируют место против CLS. */
  width?: number;
  height?: number;
}
const { src, alt, hotspots, width, height } = Astro.props as Props;
---

<figure class="full-bleed not-prose mx-auto my-8 max-w-[60rem] px-5 sm:px-6">
  <div class="hotspots-stage">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading="lazy"
      decoding="async"
      class="hotspots-img"
    />
    {
      hotspots.map((h) => (
        <button type="button" class="hotspot" style={`left:${h.x}%;top:${h.y}%`}>
          <span class="hotspot__label">
            <span class="hotspot__title">{h.title}</span>
            {h.description && <span class="hotspot__desc">{h.description}</span>}
          </span>
        </button>
      ))
    }
  </div>
</figure>

<style>
  .hotspots-stage {
    position: relative;
    line-height: 0;
  }
  .hotspots-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
    border: 1px solid var(--color-border);
  }

  /* Один морфящийся элемент: коллапс = 24×24 indigo-круг; раскрытие = тот же
     элемент вырастает до размеров своего текста (var(--pill-w/h) от скрипта),
     overflow:hidden держит круг в свёрнутом виде. Центрирован на координате,
     поэтому растёт симметрично от точки (как в видео). */
  .hotspot {
    position: absolute;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 1.5rem; /* 24px */
    height: 1.5rem; /* 24px */
    padding: 0;
    margin: 0;
    border: 0;
    border-radius: 0.75rem; /* 12px → круг в 24px, мягкие углы в pill */
    background-color: var(--color-accent); /* Indigo-9 — не меняется при морфе */
    color: var(--color-bg); /* белый текст */
    overflow: hidden;
    cursor: pointer;
    box-shadow: 0 1px 4px color-mix(in oklab, var(--color-text) 30%, transparent);
    opacity: 1; /* точки видны сразу (на всех устройствах) */
    transition:
      width 300ms ease-in-out,
      height 300ms ease-in-out;
    z-index: 1;
  }
  .hotspot:hover,
  .hotspot:focus {
    z-index: 3;
  }
  .hotspot:focus {
    outline: none;
  }
  .hotspot:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  /* Раскрытие того же элемента до размеров текста. */
  .hotspot:hover,
  .hotspot:focus {
    width: var(--pill-w, max-content);
    height: var(--pill-h, auto);
  }

  /* Текст: уже внутри элемента, фиксированной раскладки (width:max-content),
     поэтому при морфе не переносится и не «выезжает» — только fade. */
  .hotspot__label {
    width: max-content;
    max-width: 18rem;
    padding: 0.4rem 0.85rem;
    text-align: center;
    white-space: normal;
    opacity: 0;
    transition: opacity 300ms ease-in-out;
  }
  .hotspot:hover .hotspot__label,
  .hotspot:focus .hotspot__label {
    opacity: 1;
  }
  .hotspot__title {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.35;
  }
  .hotspot__desc {
    display: block;
    font-size: 0.8125rem;
    line-height: 1.35;
    opacity: 0.92;
  }

  @media (prefers-reduced-motion: reduce) {
    .hotspot,
    .hotspot__label {
      transition: none;
    }
  }
</style>

<script>
  // (1) Меряем точные размеры pill (текст + паддинги) и кладём в CSS-переменные,
  //     чтобы width/height морфились гладко за 300ms, а текст не рефлоулил.
  //     offsetWidth/Height у лейбла = его собственная раскладка (max-content,
  //     cap 18rem), не зависит от того, что родитель пока 24px с overflow:hidden.
  const hotspots = document.querySelectorAll<HTMLElement>('.hotspot');
  const measure = () => {
    for (const el of hotspots) {
      const label = el.querySelector<HTMLElement>('.hotspot__label');
      if (!label) continue;
      el.style.setProperty('--pill-w', `${Math.ceil(label.offsetWidth)}px`);
      el.style.setProperty('--pill-h', `${Math.ceil(label.offsetHeight)}px`);
    }
  };
  measure();
  // Inter подгружается асинхронно (font-display:swap) — перемеряем после загрузки,
  // чтобы размеры были точными (метрики фоллбэка близки, но добиваем точно).
  if (document.fonts?.ready) document.fonts.ready.then(measure);

  // (2) Touch: tap по пустому месту снимает фокус с раскрытой точки (на iOS
  //     :focus иначе «залипает»). Десктоп/клавиатуре не мешает.
  document.addEventListener(
    'touchstart',
    (event) => {
      const target = event.target as Element | null;
      const active = document.activeElement as HTMLElement | null;
      if (
        active &&
        active.classList.contains('hotspot') &&
        !(target && target.closest('.hotspot'))
      ) {
        active.blur();
      }
    },
    { passive: true }
  );
</script>
