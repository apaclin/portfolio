---
// Минималистичная карусель скриншотов для кейсов.
// Раскладка и swipe — нативный CSS Scroll Snap (ноль JS). Крошечный скрипт
// только для Prev/Next, стрелок клавиатуры и disabled на краях.
// Без библиотек, без autoplay/loop/dots/thumbnails — простой переход.
// Изображения — astro:assets (AVIF + WebP fallback, width/height, lazy).
import { Picture, getImage } from 'astro:assets';
import { cappedImageWidths, cappedZoomWidth } from '../../lib/images';

interface CarouselItem {
  /** Импортированное изображение из src/assets (ImageMetadata). */
  src: ImageMetadata;
  alt: string;
  caption?: string;
}
interface Props {
  items: CarouselItem[];
  /** Соотношение сторон кадра — резервирует место против CLS. */
  ratio?: string;
  /** Доступное имя карусели. */
  label?: string;
  /** CSS max-width контейнера карусели. */
  containerMaxWidth?: string;
  /** Убрать внутренние боковые отступы контейнера. */
  flush?: boolean;
  /** Грузить 1-й слайд eager — только если карусель в hero/над сгибом. */
  eager?: boolean;
  /** Логическая (CSS) ширина макета для лайтбокса: 1440 / 1920. По умолч. 1440. */
  maxWidth?: number;
}
const {
  items,
  ratio = '16 / 10',
  label = 'Screenshots',
  containerMaxWidth = '60rem',
  flush = false,
  eager = false,
  maxWidth = 1440,
} = Astro.props as Props;
const total = items.length;

const sizes = flush
  ? '(min-width: 64rem) 960px, calc(100vw - 3rem)'
  : '(min-width: 64rem) 912px, calc(100vw - 3rem)';

// Display srcsets are capped independently from the single 2× Lightbox asset.
const slides = await Promise.all(
  items.map(async (item) => {
    const widths = cappedImageWidths(item.src.width);
    const zoom = await getImage({
      src: item.src,
      width: cappedZoomWidth(item.src.width, maxWidth),
      format: 'webp',
      quality: 90,
    });

    return {
      ...item,
      widths,
      zoom: zoom.src,
    };
  })
);
---

<figure
  class:list={[
    'carousel full-bleed not-prose mx-auto max-w-[60rem]',
    !flush && 'px-5 sm:px-6',
    flush && 'px-0',
  ]}
  role="group"
  aria-roledescription="carousel"
  aria-label={label}
  style={`--carousel-ratio:${ratio};max-width:${containerMaxWidth}`}
>
  <div class="carousel__viewport">
    <ul class="carousel__track">
      {
        slides.map((item, i) => (
          <li
            class="carousel__slide"
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} of ${total}`}
          >
            <button
              type="button"
              data-zoomable
              data-zoom-src={item.zoom}
              data-zoom-alt={item.alt}
              data-max-width={maxWidth}
              aria-label={`Enlarge image: ${item.alt}`}
            >
              <Picture
                src={item.src}
                alt={item.alt}
                formats={['avif']}
                fallbackFormat="webp"
                widths={item.widths}
                sizes={sizes}
                quality={90}
                loading={eager && i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </button>
            {item.caption && <span class="carousel__caption" set:html={item.caption} />}
          </li>
        ))
      }
    </ul>

    {
      total > 1 && (
        <>
          <button
            type="button"
            class="carousel__btn carousel__btn--prev opacity-0 pointer-events-none transition-opacity duration-300"
            data-dir="-1"
            aria-label="Previous slide"
            disabled
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6" />
            </svg>
          </button>
          <button
            type="button"
            class="carousel__btn carousel__btn--next transition-opacity duration-300"
            data-dir="1"
            aria-label="Next slide"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </button>
        </>
      )
    }
  </div>
</figure>

<style>
  .carousel {
    margin-block-start: var(--space-media-before);
    padding-block-end: var(--space-media-after);
  }
  :global(.breakout) .carousel {
    margin-block-start: 0;
    padding-block-end: 0;
  }
  .carousel__viewport {
    position: relative;
  }
  .carousel__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-bg-subtle);
    scrollbar-width: none; /* убираем полосу — навигация кнопками/swipe */
  }
  .carousel__track::-webkit-scrollbar {
    display: none;
  }
  .carousel__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .carousel__slide :global([data-zoomable]) {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
  }
  .carousel__slide :global(picture) {
    display: block;
    width: 100%;
  }
  /* Кадр заполняет всю доступную ширину карусели. */
  .carousel__slide :global(img) {
    display: block;
    max-width: 100%;
    width: 100%;
    height: auto;
    margin-inline: auto;
    background-color: var(--color-bg-subtle);
  }
  .carousel__caption {
    padding: 0.5rem 0.75rem;
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }

  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
    box-shadow: 0 2px 8px color-mix(in oklab, var(--color-text) 18%, transparent);
    cursor: pointer;
    transition: opacity 300ms ease;
  }
  .carousel__btn--prev {
    left: 0.5rem;
  }
  .carousel__btn--next {
    right: 0.5rem;
  }
  .carousel__btn:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }
  .carousel__btn[disabled] {
    opacity: 0;
    pointer-events: none;
    cursor: default;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel__track {
      scroll-behavior: auto;
    }
  }
</style>

<script>
  let activeCarouselRoots: HTMLElement[] = [];
  let cleanupCarousels: (() => void) | undefined;

  const initCarousels = () => {
    const roots = [...document.querySelectorAll<HTMLElement>('.carousel')];
    const isSamePage =
      roots.length === activeCarouselRoots.length &&
      roots.every((root, index) => root === activeCarouselRoots[index]);
    if (isSamePage) return;

    cleanupCarousels?.();
    cleanupCarousels = undefined;
    activeCarouselRoots = roots;
    if (roots.length === 0) return;

    const controller = new AbortController();
    const { signal } = controller;
    const observers: Array<ResizeObserver | IntersectionObserver> = [];
    const timeoutIds = new Set<number>();
    const schedule = (callback: () => void, delay: number) => {
      const id = window.setTimeout(() => {
        timeoutIds.delete(id);
        if (!signal.aborted) callback();
      }, delay);
      timeoutIds.add(id);
    };
    const cleanup = () => {
      controller.abort();
      observers.forEach((observer) => observer.disconnect());
      timeoutIds.forEach((id) => window.clearTimeout(id));
      timeoutIds.clear();
      if (activeCarouselRoots === roots) activeCarouselRoots = [];
      if (cleanupCarousels === cleanup) cleanupCarousels = undefined;
    };
    cleanupCarousels = cleanup;
    document.addEventListener('astro:before-swap', cleanup, { once: true, signal });

    const reduceMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    roots.forEach((root) => {
      if (root.dataset.carouselReady === 'true') return;
      root.dataset.carouselReady = 'true';

      const track = root.querySelector<HTMLElement>('.carousel__track');
      const prev = root.querySelector<HTMLButtonElement>('.carousel__btn--prev');
      const next = root.querySelector<HTMLButtonElement>('.carousel__btn--next');
      if (!track) return;
      let didPreload = false;

    const indexOf = () =>
      track.clientWidth > 0 ? Math.round(track.scrollLeft / track.clientWidth) : 0;

    const go = (dir: number) => {
      track.scrollBy({
        left: dir * track.clientWidth,
        behavior: reduceMotion ? 'auto' : 'smooth',
      });
    };

    const sync = () => {
      const i = indexOf();
      const max = track.children.length - 1;
      const updateButton = (
        button: HTMLButtonElement | null,
        isDisabled: boolean
      ) => {
        if (!button) return;
        button.toggleAttribute('disabled', isDisabled);
        button.classList.toggle('opacity-0', isDisabled);
        button.classList.toggle('pointer-events-none', isDisabled);
      };
      updateButton(prev, i <= 0);
      updateButton(next, i >= max);
    };

    const preloadSlideImages = () => {
      if (didPreload) return;
      didPreload = true;

      const images = Array.from(track.querySelectorAll<HTMLImageElement>('img'));
      images.forEach((img, index) => {
        schedule(() => {
          const src = img.currentSrc || img.src;
          if (!src) return;
          const preload = new window.Image();
          preload.decoding = 'async';
          preload.src = src;
          void preload.decode?.().catch(() => undefined);
        }, index * 120);
      });
    };

    prev?.addEventListener('click', () => go(-1), { signal });
    next?.addEventListener('click', () => go(1), { signal });

    // Стрелки клавиатуры работают, пока фокус внутри карусели.
    root.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        go(-1);
      } else if (event.key === 'ArrowRight') {
        event.preventDefault();
        go(1);
      }
    }, { signal });

    track.addEventListener('scroll', () => requestAnimationFrame(() => {
      if (!signal.aborted) sync();
    }), {
      passive: true,
      signal,
    });
    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(() => requestAnimationFrame(() => {
        if (!signal.aborted) sync();
      }));
      observer.observe(track);
      observers.push(observer);
    }
    root.addEventListener('carousel:sync', () => requestAnimationFrame(() => {
      if (!signal.aborted) sync();
    }), { signal });

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries) => {
          if (!entries.some((entry) => entry.isIntersecting)) return;
          preloadSlideImages();
          observer.disconnect();
        },
        { rootMargin: '800px 0px' }
      );
      observer.observe(root);
      observers.push(observer);
    } else {
      schedule(preloadSlideImages, 600);
    }
    sync();
  });
  };

  document.addEventListener('astro:page-load', initCarousels);
  initCarousels();
</script>
