---
// Минималистичная карусель скриншотов для кейсов.
// Раскладка и swipe — нативный CSS Scroll Snap (ноль JS). Крошечный скрипт
// только для Prev/Next, стрелок клавиатуры и disabled на краях.
// Без библиотек, без autoplay/loop/dots/thumbnails — простой переход.
interface CarouselItem {
  src: string;
  alt: string;
  caption?: string;
}
interface Props {
  items: CarouselItem[];
  /** Соотношение сторон кадра — резервирует место против CLS. */
  ratio?: string;
  /** Доступное имя карусели. */
  label?: string;
}
const { items, ratio = '16 / 10', label = 'Screenshots' } = Astro.props as Props;
const total = items.length;
---

<figure
  class="carousel full-bleed not-prose mx-auto my-8 max-w-[60rem] px-5 sm:px-6"
  role="group"
  aria-roledescription="carousel"
  aria-label={label}
  style={`--carousel-ratio:${ratio}`}
>
  <div class="carousel__viewport">
    <ul class="carousel__track">
      {
        items.map((item, i) => (
          <li
            class="carousel__slide"
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} of ${total}`}
          >
            <img
              class="carousel__img"
              src={item.src}
              alt={item.alt}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
            {item.caption && <span class="carousel__caption">{item.caption}</span>}
          </li>
        ))
      }
    </ul>

    {
      total > 1 && (
        <>
          <button
            type="button"
            class="carousel__btn carousel__btn--prev"
            data-dir="-1"
            aria-label="Previous slide"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m15 18-6-6 6-6" />
            </svg>
          </button>
          <button
            type="button"
            class="carousel__btn carousel__btn--next"
            data-dir="1"
            aria-label="Next slide"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m9 18 6-6-6-6" />
            </svg>
          </button>
        </>
      )
    }
  </div>
</figure>

<style>
  .carousel__viewport {
    position: relative;
  }
  .carousel__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background-color: var(--color-bg-subtle);
    scrollbar-width: none; /* убираем полосу — навигация кнопками/swipe */
  }
  .carousel__track::-webkit-scrollbar {
    display: none;
  }
  .carousel__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .carousel__img {
    display: block;
    width: 100%;
    aspect-ratio: var(--carousel-ratio, 16 / 10);
    object-fit: contain;
    background-color: var(--color-bg-subtle);
  }
  .carousel__caption {
    padding: 0.5rem 0.75rem;
    text-align: center;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--color-text-muted);
  }

  .carousel__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 999px;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
    box-shadow: 0 2px 8px color-mix(in oklab, var(--color-text) 18%, transparent);
    cursor: pointer;
  }
  .carousel__btn--prev {
    left: 0.5rem;
  }
  .carousel__btn--next {
    right: 0.5rem;
  }
  .carousel__btn:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }
  .carousel__btn[disabled] {
    opacity: 0.4;
    cursor: default;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel__track {
      scroll-behavior: auto;
    }
  }
</style>

<script>
  const reduceMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)'
  ).matches;

  document.querySelectorAll<HTMLElement>('.carousel').forEach((root) => {
    const track = root.querySelector<HTMLElement>('.carousel__track');
    const prev = root.querySelector<HTMLButtonElement>('.carousel__btn--prev');
    const next = root.querySelector<HTMLButtonElement>('.carousel__btn--next');
    if (!track) return;

    const indexOf = () => Math.round(track.scrollLeft / track.clientWidth);

    const go = (dir: number) => {
      track.scrollBy({
        left: dir * track.clientWidth,
        behavior: reduceMotion ? 'auto' : 'smooth',
      });
    };

    const sync = () => {
      const i = indexOf();
      const max = track.children.length - 1;
      prev?.toggleAttribute('disabled', i <= 0);
      next?.toggleAttribute('disabled', i >= max);
    };

    prev?.addEventListener('click', () => go(-1));
    next?.addEventListener('click', () => go(1));

    // Стрелки клавиатуры работают, пока фокус внутри карусели.
    root.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        go(-1);
      } else if (event.key === 'ArrowRight') {
        event.preventDefault();
        go(1);
      }
    });

    track.addEventListener('scroll', () => requestAnimationFrame(sync), {
      passive: true,
    });
    sync();
  });
</script>
