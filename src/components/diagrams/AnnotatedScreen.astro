---
import { Picture } from 'astro:assets';

interface Hotspot {
  title: string;
  description: string;
  x: number;
  y: number;
}

interface Props {
  src: ImageMetadata;
  alt: string;
  title: string;
  description: string;
  hint?: string;
  cta?: string;
  replayCta?: string;
  maxWidth?: string;
  hotspots: Hotspot[];
}

const {
  src,
  alt,
  title,
  description,
  hint = 'Наведите на маркеры или запустите пошаговый разбор.',
  cta = 'Разобрать экран',
  replayCta = 'Посмотреть разбор снова',
  maxWidth = '1440px',
  hotspots,
} = Astro.props as Props;

const widths = [720, 960, 1200, 1440, 1920].filter((width) => width < src.width).concat(src.width);
const sizes = '(min-width: 92rem) 1440px, calc(100vw - 2rem)';
---

<section
  class="annotated-screen not-prose"
  data-annotated-screen
  data-cta={cta}
  data-replay-cta={replayCta}
>
  <div class="annotated-screen__intro">
    <div>
      <h2>{title}</h2>
      <p>{description}</p>
      <p class="annotated-screen__hint">{hint}</p>
    </div>
    <button class="annotated-screen__start" type="button" data-walkthrough-start>
      {cta}
    </button>
  </div>

  <div class="annotated-screen__wide relative left-1/2 w-screen -translate-x-1/2 overflow-x-auto px-4">
    <div class="annotated-screen__stage" style={`max-width: ${maxWidth};`}>
      <figure class="annotated-screen__frame">
        <Picture
          src={src}
          alt={alt}
          formats={['avif', 'webp']}
          widths={widths}
          sizes={sizes}
          loading="lazy"
          decoding="async"
        />
        <div class="annotated-screen__scrim" data-walkthrough-scrim></div>
        <div class="annotated-screen__markers" aria-label="Аннотации экрана">
          {
            hotspots.map((hotspot, index) => (
              <button
                class="annotated-screen__hotspot"
                type="button"
                style={`left: ${hotspot.x}%; top: ${hotspot.y}%;`}
                data-hotspot
                data-index={index}
                data-title={hotspot.title}
                data-description={hotspot.description}
                aria-label={`${index + 1}. ${hotspot.title}`}
              >
                <span>{index + 1}</span>
              </button>
            ))
          }
        </div>
        <div class="annotated-screen__tooltip" data-tooltip role="dialog" aria-live="polite" hidden>
          <button
            class="annotated-screen__close"
            type="button"
            data-tooltip-close
            aria-label="Закрыть разбор"
          >
            ×
          </button>
          <div class="annotated-screen__count" data-tooltip-count></div>
          <h3 data-tooltip-title></h3>
          <p data-tooltip-description></p>
          <div class="annotated-screen__actions" data-tooltip-actions>
            <button class="annotated-screen__back" type="button" data-tooltip-back>
              Назад
            </button>
            <button class="annotated-screen__next" type="button" data-tooltip-next>
              Далее
            </button>
          </div>
        </div>
      </figure>
    </div>
  </div>
</section>

<script>
  const clamp = (value: number, min: number, max: number) => Math.min(Math.max(value, min), max);

  const initAnnotatedScreen = (root: HTMLElement) => {
    if (root.dataset.ready === 'true') return;
    root.dataset.ready = 'true';

    const frame = root.querySelector<HTMLElement>('.annotated-screen__frame');
    const startButton = root.querySelector<HTMLButtonElement>('[data-walkthrough-start]');
    const tooltip = root.querySelector<HTMLDivElement>('[data-tooltip]');
    const tooltipCount = root.querySelector<HTMLElement>('[data-tooltip-count]');
    const tooltipTitle = root.querySelector<HTMLElement>('[data-tooltip-title]');
    const tooltipDescription = root.querySelector<HTMLElement>('[data-tooltip-description]');
    const tooltipActions = root.querySelector<HTMLElement>('[data-tooltip-actions]');
    const backButton = root.querySelector<HTMLButtonElement>('[data-tooltip-back]');
    const nextButton = root.querySelector<HTMLButtonElement>('[data-tooltip-next]');
    const closeButton = root.querySelector<HTMLButtonElement>('[data-tooltip-close]');
    const markers = [...root.querySelectorAll<HTMLButtonElement>('[data-hotspot]')];

    if (
      !frame ||
      !startButton ||
      !tooltip ||
      !tooltipCount ||
      !tooltipTitle ||
      !tooltipDescription ||
      !tooltipActions ||
      !backButton ||
      !nextButton ||
      !closeButton ||
      markers.length === 0
    ) {
      return;
    }
    const canHover = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
    const cta = root.dataset.cta || 'Разобрать экран';
    const replayCta = root.dataset.replayCta || 'Посмотреть разбор снова';

    let activeIndex = -1;
    let isPinned = false;
    let isGuided = false;
    let isCompleted = false;

    const setStartLabel = () => {
      startButton.textContent = isCompleted ? replayCta : cta;
    };

    const setActiveMarker = () => {
      markers.forEach((marker, index) => {
        const isActive = index === activeIndex;
        marker.classList.toggle('is-active', isActive);
        marker.setAttribute('aria-pressed', String(isActive));
      });
    };

    const updateScrimPosition = () => {
      if (activeIndex < 0) return;
      const marker = markers[activeIndex];
      const frameRect = frame.getBoundingClientRect();
      const markerRect = marker.getBoundingClientRect();
      const x = markerRect.left - frameRect.left + markerRect.width / 2;
      const y = markerRect.top - frameRect.top + markerRect.height / 2;
      frame.style.setProperty('--spot-x', `${x}px`);
      frame.style.setProperty('--spot-y', `${y}px`);
    };

    const positionTooltip = () => {
      if (activeIndex < 0) return;

      const marker = markers[activeIndex];
      tooltip.hidden = false;
      tooltip.style.visibility = 'hidden';
      tooltip.style.left = '0px';
      tooltip.style.top = '0px';

      const frameRect = frame.getBoundingClientRect();
      const markerRect = marker.getBoundingClientRect();
      const width = tooltip.offsetWidth;
      const height = tooltip.offsetHeight;
      const gap = 18;
      const pad = 12;
      const x = markerRect.left - frameRect.left + markerRect.width / 2;
      const y = markerRect.top - frameRect.top + markerRect.height / 2;
      const frameWidth = frame.clientWidth;
      const frameHeight = frame.clientHeight;

      const candidates = [
        { side: 'right', left: x + gap, top: y - height / 2 },
        { side: 'left', left: x - width - gap, top: y - height / 2 },
        { side: 'bottom', left: x - width / 2, top: y + gap },
        { side: 'top', left: x - width / 2, top: y - height - gap },
      ];

      const score = (candidate: { left: number; top: number }) => {
        const leftOverflow = Math.max(pad - candidate.left, 0);
        const rightOverflow = Math.max(candidate.left + width - frameWidth + pad, 0);
        const topOverflow = Math.max(pad - candidate.top, 0);
        const bottomOverflow = Math.max(candidate.top + height - frameHeight + pad, 0);
        return leftOverflow + rightOverflow + topOverflow + bottomOverflow;
      };

      const best = candidates.sort((a, b) => score(a) - score(b))[0];
      const left = clamp(best.left, pad, Math.max(pad, frameWidth - width - pad));
      const top = clamp(best.top, pad, Math.max(pad, frameHeight - height - pad));
      const arrowX = clamp(x - left, 18, width - 18);
      const arrowY = clamp(y - top, 18, height - 18);

      tooltip.dataset.side = best.side;
      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${top}px`;
      tooltip.style.setProperty('--arrow-x', `${arrowX}px`);
      tooltip.style.setProperty('--arrow-y', `${arrowY}px`);
      tooltip.style.visibility = 'visible';
    };

    const openTooltip = (index: number, pinned = false) => {
      activeIndex = index;
      isPinned = pinned;
      const marker = markers[index];
      tooltipTitle.textContent = marker.dataset.title || '';
      tooltipDescription.textContent = marker.dataset.description || '';
      tooltipCount.textContent = isGuided ? `${index + 1}/${markers.length}` : '';
      tooltipActions.hidden = !isGuided;
      backButton.hidden = !isGuided || index === 0;
      nextButton.textContent = index === markers.length - 1 ? 'Готово' : 'Далее';
      root.classList.toggle('is-guided', isGuided);
      setActiveMarker();
      updateScrimPosition();
      requestAnimationFrame(positionTooltip);
    };

    const closeTooltip = () => {
      activeIndex = -1;
      isPinned = false;
      tooltip.hidden = true;
      root.classList.remove('is-guided');
      setActiveMarker();
    };

    const finishGuided = () => {
      isGuided = false;
      isCompleted = true;
      setStartLabel();
      closeTooltip();
      startButton.focus();
    };

    const startGuided = () => {
      isGuided = true;
      isPinned = false;
      isCompleted = false;
      setStartLabel();
      openTooltip(0, true);
      markers[0]?.focus({ preventScroll: true });
    };

    markers.forEach((marker, index) => {
      marker.addEventListener('pointerenter', () => {
        if (!canHover || isGuided) return;
        openTooltip(index);
      });

      marker.addEventListener('pointerleave', () => {
        if (!canHover || isGuided || isPinned) return;
        closeTooltip();
      });

      marker.addEventListener('focus', () => {
        if (isGuided) return;
        openTooltip(index);
      });

      marker.addEventListener('blur', () => {
        window.setTimeout(() => {
          if (isPinned || isGuided || root.contains(document.activeElement)) return;
          closeTooltip();
        }, 0);
      });

      marker.addEventListener('click', () => {
        if (isGuided) {
          openTooltip(index, true);
          return;
        }
        if (activeIndex === index && isPinned) {
          closeTooltip();
          return;
        }
        openTooltip(index, true);
      });
    });

    startButton.addEventListener('click', startGuided);

    backButton.addEventListener('click', () => {
      if (!isGuided || activeIndex <= 0) return;
      openTooltip(activeIndex - 1, true);
      markers[activeIndex]?.focus({ preventScroll: true });
    });

    nextButton.addEventListener('click', () => {
      if (!isGuided) return;
      if (activeIndex >= markers.length - 1) {
        finishGuided();
        return;
      }
      openTooltip(activeIndex + 1, true);
      markers[activeIndex]?.focus({ preventScroll: true });
    });

    closeButton.addEventListener('click', () => {
      if (isGuided) {
        finishGuided();
        return;
      }
      closeTooltip();
    });

    root.addEventListener('keydown', (event: KeyboardEvent) => {
      if (event.key !== 'Escape') return;
      if (isGuided) {
        finishGuided();
        return;
      }
      closeTooltip();
    });

    window.addEventListener('resize', () => {
      updateScrimPosition();
      positionTooltip();
    });
  };

  document
    .querySelectorAll<HTMLElement>('[data-annotated-screen]')
    .forEach(initAnnotatedScreen);
</script>

<style>
  .annotated-screen {
    margin-block: 2rem 3rem;
  }

  .annotated-screen__intro {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .annotated-screen__intro h2 {
    margin: 0 0 0.5rem;
    color: var(--color-text);
    font-size: 1.375rem;
    line-height: 1.3;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  .annotated-screen__intro p {
    max-width: 42rem;
    margin: 0;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
  }

  .annotated-screen__hint {
    margin-top: 0.5rem !important;
    color: var(--color-text-faint) !important;
    font-size: 0.875rem !important;
    line-height: 1.5 !important;
  }

  .annotated-screen__start {
    flex: 0 0 auto;
    border-radius: 0.5rem;
    background: var(--color-primary-bg);
    padding: 0.625rem 0.875rem;
    color: var(--color-primary-fg);
    font-size: 0.875rem;
    line-height: 1;
    font-weight: 600;
    transition:
      background-color 160ms ease,
      transform 160ms ease;
  }

  .annotated-screen__start:hover {
    background: var(--color-primary-bg-hover);
  }

  .annotated-screen__start:active {
    transform: translateY(1px);
  }

  .annotated-screen__start:focus-visible,
  .annotated-screen__hotspot:focus-visible,
  .annotated-screen__tooltip button:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .annotated-screen__wide {
    overscroll-behavior-inline: contain;
  }

  .annotated-screen__stage {
    width: 100%;
    margin-inline: auto;
  }

  .annotated-screen__frame {
    --spot-x: 50%;
    --spot-y: 50%;
    position: relative;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-primary-bg);
    box-shadow: 0 12px 40px rgb(32 32 32 / 8%);
  }

  .annotated-screen__frame :global(picture),
  .annotated-screen__frame :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .annotated-screen__scrim {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    background:
      radial-gradient(
        circle at var(--spot-x) var(--spot-y),
        transparent 0,
        transparent 4.75rem,
        rgb(0 0 0 / 46%) 5.5rem
      );
    transition: opacity 180ms ease;
  }

  .annotated-screen.is-guided .annotated-screen__scrim {
    opacity: 1;
  }

  .annotated-screen__markers {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  .annotated-screen__hotspot {
    position: absolute;
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 1.5px solid var(--color-text);
    border-radius: 999px;
    background: var(--color-bg-subtle);
    color: var(--color-text);
    font-size: 0.8125rem;
    line-height: 1;
    font-weight: 700;
    box-shadow: 0 5px 16px rgb(0 0 0 / 18%);
    transform: translate(-50%, -50%);
    transition:
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .annotated-screen__hotspot::before {
    content: "";
    position: absolute;
    inset: -0.45rem;
    border: 1px solid rgb(240 240 240 / 78%);
    border-radius: inherit;
  }

  .annotated-screen__hotspot:hover,
  .annotated-screen__hotspot.is-active {
    background: var(--color-primary-bg);
    color: var(--color-primary-fg);
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 8px 24px rgb(0 0 0 / 24%);
  }

  .annotated-screen.is-guided .annotated-screen__hotspot {
    opacity: 0.72;
  }

  .annotated-screen.is-guided .annotated-screen__hotspot.is-active {
    z-index: 4;
    opacity: 1;
  }

  .annotated-screen__tooltip {
    position: absolute;
    z-index: 5;
    width: min(22rem, calc(100% - 1.5rem));
    border: 1.5px solid var(--color-text);
    border-radius: 0.5rem;
    background: var(--color-bg-subtle);
    padding: 1rem 1.5rem;
    color: var(--color-text);
    box-shadow: 0 16px 42px rgb(0 0 0 / 20%);
  }

  .annotated-screen__tooltip::after {
    content: "";
    position: absolute;
    width: 0.875rem;
    height: 0.875rem;
    border: 1.5px solid var(--color-text);
    background: var(--color-bg-subtle);
    transform: rotate(45deg);
  }

  .annotated-screen__tooltip[data-side="right"]::after {
    top: var(--arrow-y);
    left: -0.5rem;
    border-top: 0;
    border-right: 0;
  }

  .annotated-screen__tooltip[data-side="left"]::after {
    top: var(--arrow-y);
    right: -0.5rem;
    border-bottom: 0;
    border-left: 0;
  }

  .annotated-screen__tooltip[data-side="bottom"]::after {
    top: -0.5rem;
    left: var(--arrow-x);
    border-right: 0;
    border-bottom: 0;
  }

  .annotated-screen__tooltip[data-side="top"]::after {
    bottom: -0.5rem;
    left: var(--arrow-x);
    border-top: 0;
    border-left: 0;
  }

  .annotated-screen__count {
    margin-bottom: 0.375rem;
    color: var(--color-text-muted);
    font-size: 0.75rem;
    line-height: 1;
    font-weight: 600;
  }

  .annotated-screen__tooltip h3 {
    margin: 0;
    color: var(--color-text);
    font-size: 0.875rem;
    line-height: 1.35;
    font-weight: 600;
  }

  .annotated-screen__tooltip p {
    margin: 0.5rem 0 0;
    color: var(--color-text);
    font-size: 0.875rem;
    line-height: 1.5;
    font-weight: 500;
  }

  .annotated-screen__close {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    display: grid;
    width: 1.5rem;
    height: 1.5rem;
    place-items: center;
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1;
  }

  .annotated-screen__close:hover {
    background: rgb(32 32 32 / 8%);
    color: var(--color-text);
  }

  .annotated-screen__actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .annotated-screen__actions button {
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    line-height: 1;
    font-weight: 600;
  }

  .annotated-screen__back {
    color: var(--color-text);
  }

  .annotated-screen__back:hover {
    background: rgb(32 32 32 / 8%);
  }

  .annotated-screen__next {
    background: var(--color-primary-bg);
    color: var(--color-primary-fg);
  }

  .annotated-screen__next:hover {
    background: var(--color-primary-bg-hover);
  }

  @media (max-width: 47.9375rem) {
    .annotated-screen__intro {
      align-items: stretch;
      flex-direction: column;
      gap: 1rem;
    }

    .annotated-screen__start {
      width: max-content;
    }

    .annotated-screen__stage {
      min-width: 760px;
    }

    .annotated-screen__tooltip {
      width: 20rem;
    }
  }
 </style>
