---
// Общий лайтбокс для просмотра изображений. Нативный <dialog> + showModal()
// даёт top-layer, ::backdrop, Esc, focus-trap, inert фона и возврат фокуса —
// без библиотек. Подключается ОДИН раз в BaseLayout. Открывается делегированным
// кликом по любому [data-zoomable] на странице. Картинку грузит только при
// открытии → нулевое влияние на начальную загрузку.
---

<dialog class="lightbox" aria-label="Image viewer">
  <div class="lightbox__media"></div>
  <button type="button" class="lightbox__close" aria-label="Close" autofocus>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 6 6 18M6 6l12 12" />
    </svg>
  </button>
</dialog>

<style>
  .lightbox {
    width: 100%;
    height: 100%;
    max-width: 100vw;
    max-height: 100vh;
    margin: 0;
    border: 0;
    padding: 0;
    background: transparent;
    overflow: hidden;
  }
  .lightbox::backdrop {
    background-color: color-mix(in oklab, var(--color-text) 80%, transparent);
  }
  .lightbox__media {
    position: absolute;
    inset: 0;
    overflow: auto; /* картинка больше вьюпорта → скролл по обеим осям */
    display: grid;
    place-items: safe center; /* центр, если влезает; иначе скролл от края, без обрезки */
    padding: clamp(1rem, 4vw, 3rem);
    box-sizing: border-box;
  }
  /* Курсор pan только когда есть куда двигаться (картинка больше вьюпорта). */
  .lightbox__media.is-pannable {
    cursor: grab;
  }
  .lightbox__media.is-grabbing {
    cursor: grabbing;
  }
  .lightbox__media :global(img),
  .lightbox__media :global(svg) {
    display: block;
    /* Натуральный размер 1:1: без fit-to-screen и без upscale. */
    max-width: none;
    max-height: none;
    width: auto;
    height: auto;
    border-radius: 0.5rem;
    background-color: var(--color-bg);
    user-select: none;
    -webkit-user-drag: none; /* не запускать нативный drag картинки */
  }
  .lightbox__close {
    position: fixed;
    top: clamp(0.75rem, 2vw, 1.25rem);
    right: clamp(0.75rem, 2vw, 1.25rem);
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
    cursor: pointer;
  }
  .lightbox__close:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }
</style>

{/* Глобальный вид триггера зума (кнопка вокруг изображения) — единый источник. */}
<style is:global>
  button[data-zoomable] {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
    border-radius: inherit;
    color: inherit;
    font: inherit;
  }
  button[data-zoomable]:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<script>
  const dialog = document.querySelector<HTMLDialogElement>('.lightbox');
  if (dialog) {
    const media = dialog.querySelector<HTMLElement>('.lightbox__media')!;

    // Картинка больше вьюпорта → включаем «pannable» (курсор grab).
    // Маленькая картинка центрируется чистым CSS (place-items: safe center);
    // большая открывается сверху-слева (видно начало интерфейса) и панорамируется.
    const prepare = () => {
      const pannable =
        media.scrollWidth > media.clientWidth + 1 ||
        media.scrollHeight > media.clientHeight + 1;
      media.classList.toggle('is-pannable', pannable);
    };

    const open = (trigger: Element) => {
      media.replaceChildren();
      media.classList.remove('is-pannable', 'is-grabbing');
      const src = trigger.getAttribute('data-zoom-src');
      if (src) {
        // Растровое изображение: показываем тот же src в натуральном размере.
        const img = document.createElement('img');
        img.src = src;
        img.alt = trigger.getAttribute('data-zoom-alt') ?? '';
        img.decoding = 'async';
        img.draggable = false; // не запускать нативный drag картинки — мешает pan
        media.appendChild(img);
      } else {
        // SVG-диаграмма (opt-in): клонируем svg из триггера в натуральном размере.
        const svg = trigger.querySelector('svg');
        if (svg) {
          const clone = svg.cloneNode(true) as SVGElement;
          // Если у svg нет явных width/height — берём натуральный размер из viewBox,
          // чтобы он показался 1:1, а не растянулся/сжался.
          if (!clone.getAttribute('width') || !clone.getAttribute('height')) {
            const vb = (svg.getAttribute('viewBox') ?? '').split(/[\s,]+/).map(Number);
            if (vb.length === 4) {
              clone.setAttribute('width', String(vb[2]));
              clone.setAttribute('height', String(vb[3]));
            }
          }
          media.appendChild(clone);
        }
      }
      dialog.showModal();

      // Выставляем pannable + центрируем после раскладки. Для растровой
      // картинки повторяем после её загрузки (тогда известны размеры).
      requestAnimationFrame(prepare);
      const img = media.querySelector('img');
      if (img && !img.complete) {
        img.addEventListener('load', () => requestAnimationFrame(prepare), {
          once: true,
        });
      }
    };

    // Делегированный клик по любому триггеру на странице.
    document.addEventListener('click', (event) => {
      const trigger = (event.target as Element).closest('[data-zoomable]');
      if (trigger) {
        event.preventDefault();
        open(trigger);
      }
    });

    // Drag/pan «как в Figma/Notion»: тянем за саму картинку → двигаем скролл.
    // Тач не трогаем — там нативный скролл/свайп. Картинка остаётся 1:1.
    let panning = false;
    let startX = 0;
    let startY = 0;
    let startLeft = 0;
    let startTop = 0;
    let moved = 0;
    let suppressClick = false;

    media.addEventListener('pointerdown', (event) => {
      if (event.pointerType === 'touch' || event.button !== 0) return;
      if (!(event.target as Element).closest('.lightbox__media > *')) return; // только по картинке
      panning = true;
      moved = 0;
      startX = event.clientX;
      startY = event.clientY;
      startLeft = media.scrollLeft;
      startTop = media.scrollTop;
      media.setPointerCapture(event.pointerId);
      media.classList.add('is-grabbing');
    });
    media.addEventListener('pointermove', (event) => {
      if (!panning) return;
      const dx = event.clientX - startX;
      const dy = event.clientY - startY;
      moved = Math.max(moved, Math.abs(dx) + Math.abs(dy));
      media.scrollLeft = startLeft - dx;
      media.scrollTop = startTop - dy;
    });
    const endPan = (event: PointerEvent) => {
      if (!panning) return;
      panning = false;
      media.releasePointerCapture?.(event.pointerId);
      media.classList.remove('is-grabbing');
      if (moved > 5) suppressClick = true; // после драга не закрываем
    };
    media.addEventListener('pointerup', endPan);
    media.addEventListener('pointercancel', endPan);

    // Закрытие: клик по фону (всё, кроме картинки) или по кнопке Close.
    // Если только что был pan-драг — клик игнорируем.
    dialog.addEventListener('click', (event) => {
      if (suppressClick) {
        suppressClick = false;
        return;
      }
      const t = event.target as Element;
      if (!t.closest('.lightbox__media > *')) dialog.close();
    });
    // Esc и возврат фокуса на триггер обеспечивает сам <dialog>.
  }
</script>
