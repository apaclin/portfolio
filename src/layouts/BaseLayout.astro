---
import { getRelativeLocaleUrl } from 'astro:i18n';
import '../styles/global.css';
import LangSwitcher from '../components/LangSwitcher.astro';
import Lightbox from '../components/Lightbox.astro';
import { stripLocale } from '../i18n/paths';

interface Props {
  /** Содержимое <title>. */
  title: string;
  /** Необязательное meta-описание для <head>. */
  description?: string;
}

const { title, description } = Astro.props;

// Astro.currentLocale вычисляется из URL по конфигу i18n.
// Если в пути нет языкового сегмента (например, на «/»), он может быть
// undefined — тогда подставляем основной язык сайта.
const lang = Astro.currentLocale ?? 'ru';

// hreflang: alternate-ссылки на en/ru версии ТЕКУЩЕЙ страницы + x-default → ru.
const basePath = stripLocale(Astro.url.pathname);
const enUrl = getRelativeLocaleUrl('en', basePath);
const ruUrl = getRelativeLocaleUrl('ru', basePath);
// Относительные ссылки сейчас; станут абсолютными автоматически, когда в
// astro.config будет задан `site` (Google рекомендует абсолютные hreflang).
const toAbs = (url: string) => (Astro.site ? new URL(url, Astro.site).href : url);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Preload основного начертания: latin всегда, cyrillic только на /ru/. */}
    <link
      rel="preload"
      href="/fonts/inter-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      lang === 'ru' && (
        <link
          rel="preload"
          href="/fonts/inter-cyrillic.woff2"
          as="font"
          type="font/woff2"
          crossorigin
        />
      )
    }
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <link rel="alternate" hreflang="en" href={toAbs(enUrl)} />
    <link rel="alternate" hreflang="ru" href={toAbs(ruUrl)} />
    <link rel="alternate" hreflang="x-default" href={toAbs(ruUrl)} />
    <title>{title}</title>
  </head>
  <body class="font-sans">
    <header class="mx-auto flex max-w-[42rem] justify-end px-5 pt-6">
      <LangSwitcher />
    </header>
    <slot />
    <Lightbox />
  </body>
</html>
